---
import { createT } from '../i18n';

const { lang } = Astro.props as { lang: string };
const t = createT(lang);

const links = [
  { label: 'projects', href: '/' + lang + '/projects', key: 'nav.projects' },
  { label: 'LibreCourseUY', href: '/' + lang + '/#librecourseuy', key: 'nav.librecourse' },
  { label: 'open source', href: '/' + lang + '/#oss', key: 'nav.opensource' },
  { label: 'about', href: '/' + lang + '/#about', key: 'nav.about' },
  { label: 'blog ↗', href: 'https://blog.emiliano-go.com', external: true, key: 'nav.blog' },
];
---

<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-(--color-border-subtle) opacity-0 bg-(--color-bg)/95"
  style="backdrop-filter: blur(12px);"
>
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0 flex items-center justify-between py-5">
    <a href={'/' + lang} class="font-[family-name:var(--font-display)] text-lg font-bold tracking-widest uppercase text-(--color-text-head)">{t("nav.logo")}</a>
    <ul class="hidden md:flex md:gap-5 lg:gap-7 list-none">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="nav-link text-xs tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
          >{t(link.key)}</a>
        </li>
      ))}
      <li class="flex items-center gap-2">
        <div class="relative">
          <a href={'/' + lang} class="flex items-center gap-1 px-2 py-1 border border-(--color-border) rounded text-xs tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">
            {lang.toUpperCase()} <span class="text-[10px]">▾</span>
          </a>
          <div class="absolute right-0 top-full mt-1 min-w-[68px] bg-(--color-bg) border border-(--color-border) rounded shadow-lg opacity-0 pointer-events-none transition-opacity duration-150 z-50 group-hover:opacity-100 group-hover:pointer-events-auto hover:opacity-100 hover:pointer-events-auto" style="display:none" id="lang-dd-desk">
          </div>
        </div>
        <button id="theme-toggle-desktop" class="flex items-center px-2 py-1 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200 cursor-pointer" aria-label="Toggle theme">
          <svg id="sun-icon" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg id="moon-icon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </li>
    </ul>
    <div class="md:hidden flex items-center gap-2">
      <button id="theme-toggle-mobile" class="text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200 cursor-pointer" aria-label="Toggle theme">
        <svg id="sun-icon-mobile" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg id="moon-icon-mobile" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button id="menu-btn" class="flex flex-col gap-1.5 p-2 cursor-pointer relative z-10" aria-label="Toggle menu">
        <span class="block w-5 h-px bg-(--color-text-muted) transition-all duration-200"></span>
        <span class="block w-5 h-px bg-(--color-text-muted) transition-all duration-200"></span>
        <span class="block w-5 h-px bg-(--color-text-muted) transition-all duration-200"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div id="mobile-menu" class="md:hidden fixed inset-0 z-40 pt-20 opacity-0 pointer-events-none transition-opacity duration-300 bg-(--color-bg)">
  <button id="menu-close" class="absolute top-6 right-[7.5%] md:hidden text-(--color-text-muted) hover:text-(--color-text-bright) text-2xl cursor-pointer" aria-label="Close menu">✕</button>
  <ul class="flex flex-col items-center gap-8 pt-16 list-none">
    {links.map((link) => (
      <li>
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="text-lg tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
          >{t(link.key)}</a>
        </li>
      ))}
      <li class="flex items-center justify-center gap-4">
        <div class="flex items-center gap-2" id="mobile-lang-links">
          <a href={'/' + lang} class="px-3 py-1.5 text-lg tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200" data-lang="en">EN</a>
          <a href={'/' + lang} class="px-3 py-1.5 text-lg tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200" data-lang="es">ES</a>
          <a href={'/' + lang} class="px-3 py-1.5 text-lg tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200" data-lang="fr">FR</a>
        </div>
        <button id="theme-toggle-overlay" class="flex items-center gap-2 text-lg tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200 cursor-pointer" aria-label="Toggle theme">
          <svg id="sun-icon-overlay" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg id="moon-icon-overlay" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
    </li>
  </ul>
</div>

<script is:inline>
  (function() {
    var nav = document.getElementById('nav');
    var curLang = document.documentElement.lang || 'en';

    // Build language switcher links using current path
    function currentPath() {
      var p = location.pathname;
      // Strip language prefix if present
      var m = p.match(/^\/(en|es|fr)(\/.*)?$/);
      return m ? (m[2] || '/') : p;
    }

    var desktopDD = document.getElementById('lang-dd-desk');
    if (desktopDD) {
      var langs = ['en', 'es', 'fr'];
      var html = '';
      for (var i = 0; i < langs.length; i++) {
        var l = langs[i];
        if (l === curLang) continue;
        html += '<a href="/' + l + currentPath() + '" class="block px-3 py-1.5 text-xs tracking-wide text-(--color-text-muted) hover:text-(--color-text-bright) hover:bg-(--color-border-subtle) transition-colors duration-150">' + l.toUpperCase() + '</a>';
      }
      desktopDD.innerHTML = html;
      desktopDD.style.display = 'block';
    }

    // Mobile lang links: update href to include current path
    var mobileLinks = document.getElementById('mobile-lang-links');
    if (mobileLinks) {
      var cp = currentPath();
      mobileLinks.querySelectorAll('a').forEach(function(a) {
        var l = a.getAttribute('data-lang');
        if (l) a.href = '/' + l + cp;
        if (l === curLang) a.style.fontWeight = 'bold';
      });
    }

    // Desktop lang dropdown hover
    var ddContainer = document.querySelector('.relative');
    if (ddContainer) {
      ddContainer.classList.add('group');
      var dd = desktopDD;
      ddContainer.addEventListener('mouseenter', function() {
        dd.classList.remove('opacity-0', 'pointer-events-none');
        dd.classList.add('opacity-100', 'pointer-events-auto');
      });
      ddContainer.addEventListener('mouseleave', function() {
        dd.classList.remove('opacity-100', 'pointer-events-auto');
        dd.classList.add('opacity-0', 'pointer-events-none');
      });
    }

    window.addEventListener('scroll', function() {
      nav.style.borderBottomColor = window.scrollY > 40
        ? 'var(--color-border)'
        : 'var(--color-border-subtle)';
    }, { passive: true });

    var menuBtn = document.getElementById('menu-btn');
    var mobileMenu = document.getElementById('mobile-menu');
    var bars = menuBtn.querySelectorAll('span');

    menuBtn.addEventListener('click', function() {
      var open = mobileMenu.classList.contains('opacity-100');
      if (open) {
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        bars.forEach(function(b) { b.style.transform = ''; b.style.backgroundColor = ''; });
      } else {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
        bars[0].style.transform = 'translateY(7px) rotate(45deg)';
        bars[1].style.transform = 'scaleX(0)';
        bars[2].style.transform = 'translateY(-7px) rotate(-45deg)';
      }
    });

    mobileMenu.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() {
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        bars.forEach(function(b) { b.style.transform = ''; b.style.backgroundColor = ''; });
      });
    });

    function setTheme(light) {
      var html = document.documentElement;
      if (light) {
        html.classList.add('light');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.remove('light');
        localStorage.setItem('theme', 'dark');
      }
      updateIcons();
    }

    function updateIcons() {
      var isLight = document.documentElement.classList.contains('light');
      document.querySelectorAll('[id^="sun-icon"]').forEach(function(el) { el.classList.toggle('hidden', !isLight); });
      document.querySelectorAll('[id^="moon-icon"]').forEach(function(el) { el.classList.toggle('hidden', isLight); });
    }

    document.querySelectorAll('[id^="theme-toggle"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var isLight = document.documentElement.classList.contains('light');
        setTheme(!isLight);
      });
    });

    updateIcons();
  })();
</script>

<style>
  @keyframes nav-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  #nav {
    animation: nav-fade-in 0.6s ease-out 1.2s forwards;
  }

  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--color-text-bright);
    transition: width 0.25s ease, left 0.25s ease;
  }
  .nav-link:hover::after {
    width: 100%;
    left: 0;
  }
</style>
