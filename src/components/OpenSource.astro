---
---

<section id="oss" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

    <div data-reveal data-delay="0" class="flex items-center gap-4 mb-10">
      <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
        Open Source
      </span>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">

      <div data-reveal data-delay="0.1" class="border border-(--color-border-subtle) bg-(--color-surface) p-6">
        <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">Co-maintainer</p>
        <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-3">
          FastAPI-boilerplate
        </h3>
        <p class="text-xs leading-[1.7] text-(--color-text-muted) mb-4">
          Async FastAPI template with SQLAlchemy 2.0, Pydantic V2, PostgreSQL, Redis, and a plugin system.
          Contributor to documentation and project maintenance.
        </p>
        <p class="text-[11px] text-(--color-text-muted) mb-4">
          <span class="text-(--color-text-bright)">~2k</span> stars ·
          <span class="text-(--color-text-bright)">286</span> forks
        </p>
        <a
          href="https://github.com/benavlabs/FastAPI-boilerplate"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
        >
          View on GitHub ↗
        </a>
      </div>

      <div data-reveal data-delay="0.18" class="pt-0 md:pt-2">
        <p class="text-[13px] leading-[1.8] text-(--color-text-muted) mb-4">
          I focus on documentation quality and keeping the project accessible to people building
          real things with FastAPI. Named co-maintainer in v0.18.0 — the pluggable restructure release.
        </p>
        <div class="flex flex-wrap gap-2">
          {['FastAPI', 'SQLAlchemy 2.0', 'Pydantic V2', 'Async Python'].map(t => (
            <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
