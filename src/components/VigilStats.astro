---
// loaded client-side via /vigil-data
---

<section class="py-16 border-b border-(--color-border-subtle)" id="vigil-section">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">
    <div class="flex items-center gap-4 mb-10">
      <h2 class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap" data-i18n="vigil.heading">
        GitHub Activity
      </h2>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
      <a href="https://github.com/emiliano-go/vigil" target="_blank" rel="noopener noreferrer" class="text-[9px] uppercase tracking-[0.1em] text-(--color-text-dim) hover:text-(--color-accent) transition-colors whitespace-nowrap">
        Provided by Vigil
      </a>
    </div>

    <div id="vigil-root">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle) mb-8">
        <div class="bg-(--color-surface) p-4 flex flex-col gap-3"><div class="h-3 w-20 bg-(--color-text-dim)/10 rounded animate-pulse"></div><div class="h-7 w-16 bg-(--color-text-dim)/10 rounded animate-pulse"></div></div>
        <div class="bg-(--color-surface) p-4 flex flex-col gap-3"><div class="h-3 w-12 bg-(--color-text-dim)/10 rounded animate-pulse"></div><div class="h-7 w-12 bg-(--color-text-dim)/10 rounded animate-pulse"></div></div>
        <div class="bg-(--color-surface) p-4 flex flex-col gap-3"><div class="h-3 w-16 bg-(--color-text-dim)/10 rounded animate-pulse"></div><div class="h-7 w-20 bg-(--color-text-dim)/10 rounded animate-pulse"></div></div>
        <div class="bg-(--color-surface) p-4 flex flex-col gap-3"><div class="h-3 w-16 bg-(--color-text-dim)/10 rounded animate-pulse"></div><div class="h-7 w-28 bg-(--color-text-dim)/10 rounded animate-pulse"></div></div>
      </div>
      <div class="mb-8">
        <div class="h-3 w-44 bg-(--color-text-dim)/10 rounded animate-pulse mb-3"></div>
        <div class="flex gap-[3px] h-24">
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:30%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:55%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:80%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:100%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:70%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:45%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:60%"></div></div>
        </div>
      </div>
      <div>
        <div class="h-3 w-48 bg-(--color-text-dim)/10 rounded animate-pulse mb-3"></div>
        <div class="flex gap-[2px] h-28">
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:20%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:35%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:50%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:65%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:80%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:95%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:70%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:50%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:30%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:15%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:25%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:40%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:55%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:70%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:85%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:60%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:40%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:25%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:35%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:50%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:65%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:80%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:45%"></div></div>
          <div class="flex-1 flex flex-col justify-end"><div class="w-full bg-(--color-text-dim)/10 rounded animate-pulse" style="height:30%"></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(async function() {
  var root = document.getElementById('vigil-root');
  if (!root) return;

  var data;
  try {
    data = await fetch('/vigil-data').then(function(r) { if (!r.ok) throw new Error(); return r.json(); });
  } catch { data = null; }
  if (!data || !data.myStats) { root.innerHTML = '<div class="text-center py-12 text-sm text-(--color-text-dim)">Stats unavailable</div>'; return; }

  var s = data.myStats;
  var lastWeekDaily = data.lastWeekDaily || [];
  var lastWeekHourly = data.lastWeekHourly || [];
  var lastHourPeriods = data.last24hPeriods || [];
  var fetchedAt = data.fetchedAt || '';

  var maxHourly = Math.max.apply(null, lastWeekHourly.concat([1]));
  var hourLabels = data.hourLabels || [];
  var maxDaily = Math.max.apply(null, lastWeekDaily.map(function(d) { return d.total; }).concat([1]));

  function ago(iso) {
    var now = Date.now();
    var then = new Date(iso.endsWith('Z') ? iso : iso + 'Z').getTime();
    var diff = now - then;
    if (diff < 60000) return 'just now';
    var mins = Math.floor(diff / 60000);
    if (mins < 60) return mins + 'm ago';
    var hrs = Math.floor(mins / 60);
    if (hrs < 24) return hrs + 'h ago';
    var days = Math.floor(hrs / 24);
    if (days < 7) return days + 'd ago';
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function dayLabel(period) {
    return new Date(period + 'Z').toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
  }

  var hourFormatter = new Intl.DateTimeFormat('en-GB', { hour: '2-digit', hour12: false });

  function hourLabel(period) {
    if (!period) return '--';
    return hourFormatter.format(new Date(period));
  }

  var html = '';

  html += '<div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle) mb-8">';
  html += '<div class="bg-(--color-surface) p-4 flex flex-col gap-1"><span class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">total commits</span><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">' + (s.totalCommits ? s.totalCommits.toLocaleString() : '-') + '</span></div>';
  html += '<div class="bg-(--color-surface) p-4 flex flex-col gap-1"><span class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">streak</span><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">' + (s.streak ?? '-') + '</span>' + (s.streak > 0 ? '<span class="text-xs text-(--color-text-muted)">consecutive days</span>' : '') + '</div>';
  html += '<div class="bg-(--color-surface) p-4 flex flex-col gap-1"><span class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">commits (24h)</span><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">' + (data.last24hTotal != null ? data.last24hTotal.toLocaleString() : '-') + '</span></div>';
  html += '<div class="bg-(--color-surface) p-4 flex flex-col gap-1"><span class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">repo (last 7d)</span><span class="font-[family-name:var(--font-display)] text-lg font-bold text-(--color-text-head) truncate" title="' + (s.mostActiveRepoWeek || '') + '">' + (s.mostActiveRepoWeek || '-') + '</span>' + (s.mostActiveRepoWeekTotal ? '<span class="text-xs text-(--color-text-muted)">' + s.mostActiveRepoWeekTotal + ' commits</span>' : '') + '</div>';
  html += '</div>';

  if (lastWeekDaily.length > 0) {
    html += '<div class="mb-8"><h3 class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-3">Daily commits (last 7 days)</h3><div class="flex gap-[3px] h-24">';
    for (var i = 0; i < lastWeekDaily.length; i++) {
      var d = lastWeekDaily[i];
      var pct = (d.total / maxDaily) * 100;
      html += '<div class="flex-1 flex flex-col items-center justify-end gap-1 group relative h-full">';
      html += '<div class="w-full bg-(--color-accent-dim)/30 rounded-t-sm" style="height:' + pct + '%"><div class="w-full h-full bg-(--color-accent-dim)/60 rounded-t-sm"></div></div>';
      html += '<div class="absolute bottom-full mb-1 hidden group-hover:block bg-(--color-bg) border border-(--color-border-subtle) px-2 py-1 text-[10px] text-(--color-text-muted) whitespace-nowrap z-10 rounded">' + dayLabel(d.period) + ' - ' + d.total + '</div>';
      html += '</div>';
    }
    html += '</div></div>';
  }

  html += '<div><h3 class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-3">Hourly commits (last 24h)</h3><div class="flex gap-[2px] h-28">';
  for (var h = 0; h < lastWeekHourly.length; h++) {
    var t = lastWeekHourly[h];
    var label = hourLabel(lastHourPeriods[h] || '');
    var pct = (t / maxHourly) * 100;
    var opacity = Math.round((t / maxHourly) * 50 + 50);
    html += '<div class="flex-1 flex flex-col items-center justify-end gap-1 group relative h-full">';
    html += '<div class="w-full rounded-t-sm" style="height:' + pct + '%;background:color-mix(in srgb, var(--color-accent) ' + opacity + '%,transparent)"><div class="w-full h-full rounded-t-sm opacity-0 group-hover:opacity-40 transition-opacity duration-200"></div></div>';
    html += '<div class="absolute bottom-full mb-1 hidden group-hover:block bg-(--color-bg) border border-(--color-border-subtle) px-2 py-1 text-[10px] text-(--color-text-muted) whitespace-nowrap z-10 rounded">' + label + ':00 - ' + t + '</div>';
    html += '</div>';
  }
  html += '</div><div class="flex justify-between mt-2 text-[9px] text-(--color-text-dim) tracking-wide">';
  var labelSlots = {};
  if (lastWeekHourly.length > 0) {
    labelSlots[0] = true;
    labelSlots[Math.floor((lastWeekHourly.length - 1) / 4)] = true;
    labelSlots[Math.floor((lastWeekHourly.length - 1) / 2)] = true;
    labelSlots[Math.floor(((lastWeekHourly.length - 1) * 3) / 4)] = true;
    labelSlots[lastWeekHourly.length - 1] = true;
  }
  for (var li = 0; li < lastWeekHourly.length; li++) {
    if (labelSlots[li]) {
      html += '<span>' + hourLabel(lastHourPeriods[li] || '') + '</span>';
    }
  }
  html += '</div></div>';

  if (fetchedAt) {
    html += '<p class="text-[9px] text-(--color-text-dim) mt-4 text-right">Updated<span>&nbsp;</span><time datetime="' + fetchedAt + '">' + ago(fetchedAt) + '</time></p>';
  }

  root.innerHTML = html;

  var times = root.querySelectorAll('time');
  for (var i = 0; i < times.length; i++) {
    times[i].textContent = ago(times[i].getAttribute('datetime'));
  }
})();
</script>
