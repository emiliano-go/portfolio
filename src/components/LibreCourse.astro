---
import { createT } from "../i18n";
const t = createT(Astro.props.lang);
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<section id="librecourseuy" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0">

    <div class="flex items-center gap-4 mb-10">
      <h2 class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">{t("librecourse.heading")}</h2>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <div class="border border-(--color-border-subtle) bg-(--color-surface) transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
      <div class="p-6">
        <div class="flex items-start justify-between gap-8">
          <div class="flex-1">
            <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-3">{t("librecourse.tag")}</p>
            <h2 class="font-[family-name:var(--font-display)] text-[28px] sm:text-[40px] md:text-[48px] font-bold uppercase tracking-wide text-(--color-text-head) mb-5">{t("librecourse.title")}</h2>
            <p class="text-sm leading-relaxed text-(--color-text-muted) mb-3">{t("librecourse.desc.1")}</p>
            <p class="text-sm leading-relaxed text-(--color-text-muted) mb-6">{t("librecourse.desc.2")}</p>
            <div class="flex flex-wrap gap-3 md:gap-5">
              <a
                href="https://github.com/LibreCourseUY"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
              >{t("librecourse.github")}</a>
              <div id="discord-container" class="flex items-center gap-3">
                <button id="discord-verify-btn" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200 cursor-pointer">{t("librecourse.discord.join")}</button>
                <div id="turnstile-wrapper" class="hidden"></div>
                <a
                  id="discord-revealed"
                  href="https://discord.gg/ENTX7nQ9Cs"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hidden items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
                >{t("librecourse.discord.open")}</a>
              </div>

              <script>
                const verifyBtn = document.getElementById('discord-verify-btn');
                const turnstileWrapper = document.getElementById('turnstile-wrapper');
                const discordRevealed = document.getElementById('discord-revealed');

                verifyBtn.addEventListener('click', () => {
                  verifyBtn.classList.add('hidden');
                  turnstileWrapper.classList.remove('hidden');
                  if (window.turnstile) {
                    window.turnstile.render(turnstileWrapper, {
                      sitekey: '0x4AAAAAADuKHgIJh6d_dCLH',
                      theme: 'dark',
                      callback: () => {
                        turnstileWrapper.classList.add('hidden');
                        discordRevealed.classList.remove('hidden');
                        discordRevealed.classList.add('flex');
                      },
                    });
                  } else {
                    turnstileWrapper.textContent = 'Loading verification...';
                    const check = setInterval(() => {
                      if (window.turnstile) {
                        clearInterval(check);
                        turnstileWrapper.textContent = '';
                        window.turnstile.render(turnstileWrapper, {
                          sitekey: '0x4AAAAAADuKHgIJh6d_dCLH',
                          theme: 'dark',
                          callback: () => {
                            turnstileWrapper.classList.add('hidden');
                            discordRevealed.classList.remove('hidden');
                            discordRevealed.classList.add('flex');
                          },
                        });
                      }
                    }, 200);
                  }
                });
              </script>
              <a
                href="https://librecourse.uy"
                class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-accent-dim) rounded hover:border-(--color-accent) text-(--color-accent) hover:text-(--color-text-bright) transition-colors duration-200" data-i18n-html set:html={t("librecourse.learn")}>

            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
