---
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<section id="librecourseuy" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

    <div class="flex items-center gap-4 mb-10">
      <h2 class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
        LibreCourseUY
      </h2>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <div class="border border-(--color-border-subtle) bg-(--color-surface) transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
      <div class="p-6">
        <div class="flex items-start justify-between gap-8">
          <div class="flex-1">
            <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-3">Open Source · Uruguay</p>
            <h2 class="font-[family-name:var(--font-display)] text-[28px] sm:text-[40px] md:text-[48px] font-bold uppercase tracking-wide text-(--color-text-head) mb-5">
              LibreCourseUY
            </h2>
            <p class="text-sm leading-relaxed text-(--color-text-muted) mb-3">
              An open source organization focused on promoting the FOSS ecosystem in Uruguay.
              We build and maintain free tools, services, and infrastructure for the Uruguayan
              developer community, and anyone who wants to contribute.
            </p>
            <p class="text-sm leading-relaxed text-(--color-text-muted) mb-6">
              What started as a small side project to help some friends grew into a 30-person operation
              with hundreds of members, all focused on learning, growing together, and building useful projects for our country.
            </p>
            <div class="flex flex-wrap gap-3 md:gap-5">
              <a
                href="https://github.com/LibreCourseUY"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
              >
                <svg class="w-4 h-4 md:w-3.5 md:h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                GitHub
              </a>
              <div id="discord-container" class="flex items-center gap-3">
                <button id="discord-verify-btn" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200 cursor-pointer">
                  <svg class="w-4 h-4 md:w-3.5 md:h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  Join Discord
                </button>
                <div id="turnstile-wrapper" class="hidden"></div>
                <a
                  id="discord-revealed"
                  href="https://discord.gg/ENTX7nQ9Cs"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hidden items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
                >
                  <svg class="w-4 h-4 md:w-3.5 md:h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 12a1 1 0 1 0 2 0 1 1 0 0 0-2 0Zm6 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0Z"/><path d="M15.5 17.5c3 1.5 6 1 7.5-1.5 1-3 .5-6-1.5-9-1.5-2.25-4.25-3-6.5-3h-2C10.25 4 7.5 4.75 6 7c-2 3-2.5 6-1.5 9 1.5 2.5 4.5 3 7.5 1.5Z"/><path d="M12 4c-2.5-1-5.5-.5-8 2-2 2-3 5-2.5 8 .5 2.5 2.5 4.5 4.5 5.5"/></svg>
                  Discord
                </a>
              </div>

              <script>
                const verifyBtn = document.getElementById('discord-verify-btn');
                const turnstileWrapper = document.getElementById('turnstile-wrapper');
                const discordRevealed = document.getElementById('discord-revealed');

                verifyBtn.addEventListener('click', () => {
                  verifyBtn.classList.add('hidden');
                  turnstileWrapper.classList.remove('hidden');
                  if (window.turnstile) {
                    window.turnstile.render(turnstileWrapper, {
                      sitekey: '0x4AAAAAADuKHgIJh6d_dCLH',
                      theme: 'dark',
                      callback: () => {
                        turnstileWrapper.classList.add('hidden');
                        discordRevealed.classList.remove('hidden');
                        discordRevealed.classList.add('flex');
                      },
                    });
                  } else {
                    turnstileWrapper.textContent = 'Loading verification...';
                    const check = setInterval(() => {
                      if (window.turnstile) {
                        clearInterval(check);
                        turnstileWrapper.textContent = '';
                        window.turnstile.render(turnstileWrapper, {
                          sitekey: '0x4AAAAAADuKHgIJh6d_dCLH',
                          theme: 'dark',
                          callback: () => {
                            turnstileWrapper.classList.add('hidden');
                            discordRevealed.classList.remove('hidden');
                            discordRevealed.classList.add('flex');
                          },
                        });
                      }
                    }, 200);
                  }
                });
              </script>
              <a
                href="https://librecourse.uy"
                class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-accent-dim) rounded hover:border-(--color-accent) text-(--color-accent) hover:text-(--color-text-bright) transition-colors duration-200"
              >
                Learn more <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
