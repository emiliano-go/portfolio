---
---

<section id="librecourseuy" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[60%] max-w-none min-w-[320px]">

    <div data-reveal data-delay="0" class="flex items-center gap-4 mb-10">
      <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
        LibreCourseUY
      </span>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <div data-reveal data-delay="0.1" class="border border-(--color-border-subtle) bg-(--color-surface)">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">

        <!-- Left: identity -->
        <div class="p-8 border-b md:border-b-0 md:border-r border-(--color-border-subtle)">
          <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-4">Open Source · Uruguay</p>
          <h2
            class="font-[family-name:var(--font-display)] text-[52px] font-bold uppercase leading-[0.88] tracking-wide text-(--color-text-head) mb-6"
            style="word-break: keep-all; white-space: nowrap;"
          >
            Libre<br />Course<br />UY
          </h2>
          <div class="flex flex-wrap gap-4">
            <a
              href="https://github.com/LibreCourseUY"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[11px] text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200 border-b border-(--color-border) hover:border-(--color-text-muted) pb-px"
            >
              GitHub ↗
            </a>
            <a
              href="https://discord.gg/librecourseuy"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[11px] text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200 border-b border-(--color-border) hover:border-(--color-text-muted) pb-px"
            >
              Discord ↗
            </a>
            <a
              href="/librecourseuy"
              class="text-[11px] text-(--color-accent) hover:text-(--color-text-bright) transition-colors duration-200 border-b border-(--color-accent-dim) hover:border-(--color-accent) pb-px"
            >
              Learn more →
            </a>
          </div>
        </div>

        <!-- Right: description -->
        <div class="p-8 flex flex-col justify-center gap-4">
          <p class="text-[13px] leading-[1.8] text-(--color-text-muted)">
            An open source organization focused on promoting the OSS ecosystem in Uruguay.
            We build and maintain free tools, services, and infrastructure for the Uruguayan
            developer community — and anyone who wants to contribute.
          </p>
          <p class="text-[13px] leading-[1.8] text-(--color-text-muted)">
            Multiple services running in production on a self-hosted VPS, managed with Docker,
            Traefik, and automated CI/CD via GitHub Actions. Open to contributors at any level.
          </p>
        </div>

      </div>
    </div>

  </div>
</section>
