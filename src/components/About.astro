---
const stack = [
  { name: 'Python',     cat: 'core' },
  { name: 'FastAPI',    cat: 'api' },
  { name: 'pandas',     cat: 'data' },
  { name: 'scikit-learn', cat: 'ml' },
  { name: 'matplotlib', cat: 'eda' },
  { name: 'PostgreSQL', cat: 'db' },
  { name: 'Prefect',    cat: 'pipelines' },
  { name: 'Redis',      cat: 'cache' },
  { name: 'Docker',     cat: 'infra' },
  { name: 'Traefik',    cat: 'infra' },
  { name: 'Vue 3',      cat: 'frontend' },
  { name: 'Taskiq',     cat: 'workers' },
];
---

<section id="about" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0">

    <div class="flex items-center gap-4 mb-10">
      <h2 class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap" data-i18n="about.heading">
        About
      </h2>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">

      <div>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(28px,6vw,44px)] font-bold uppercase leading-[0.92] tracking-wide text-(--color-text-head) mb-2" data-i18n="about.name" data-i18n-html>
          Emiliano<br />G.O.
        </h2>
        <p class="text-xs text-(--color-text-dim) mb-8 tracking-wide" data-i18n="about.location">Montevideo, Uruguay</p>
        <p class="text-sm leading-relaxed text-(--color-text-muted) mb-4" data-i18n="about.bio.1">
          Backend developer and data scientist. I work mostly in Python: pipelines, APIs, and
          the infrastructure that keeps them running. I care about clean architecture,
          good documentation, and building things that hold up under load.
        </p>
        <p class="text-sm leading-relaxed text-(--color-text-muted) mb-4" data-i18n="about.bio.2">
          I learn by building things until they break, then figuring out why. Also run LibreCourseUY,
          an open source organization promoting the OSS ecosystem in Uruguay.
        </p>
        <p class="text-sm leading-relaxed text-(--color-text-muted)" data-i18n="about.bio.3">
          Arch (btw) :D
        </p>
      </div>

      <div>
        <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-4" data-i18n="about.stack">Stack</p>
        <div class="grid grid-cols-2 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle)">
          {stack.map((item) => (
            <div class="flex justify-between items-center gap-2 px-2 py-2.5 bg-(--color-bg) text-[11px]">
              <span class="text-(--color-text-muted) truncate min-w-0">{item.name}</span>
              <span class="text-(--color-text-dim) text-[10px] shrink-0">{item.cat}</span>
            </div>
          ))}
        </div>

        <a
          href="https://blog.emiliano-go.com"
          target="_blank"
          rel="noopener noreferrer"
          class="group block border border-(--color-border-subtle) bg-(--color-surface) hover:bg-(--color-bg) transition-colors duration-200 p-5 mt-5 rounded"
        >
          <div class="flex items-center justify-between mb-1">
            <span class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)" data-i18n="about.blog">blog</span>
            <span class="text-(--color-border) group-hover:text-(--color-text-muted) transition-colors duration-200 text-sm">↗</span>
          </div>
          <p class="text-sm leading-relaxed text-(--color-text-muted)" data-i18n="about.blog.desc">
            Thoughts on backend, data, and building things.
          </p>
        </a>

        <div class="flex flex-wrap items-center gap-2 mt-3">
          <a
            href="https://www.linkedin.com/in/emiliano-go"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-1.5 text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a
            href="https://github.com/emiliano-go"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-1.5 text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
