---

const projects = [
  {
    tag: 'Python Package · PyPI',
    name: 'DBWarden',
    desc: 'DBWarden is a SQL-first migration system for SQLAlchemy that replaces Python-based migration workflows with explicit, reviewable SQL generated directly from your models. No migration runtime, no generated Python scripts. Built-in rollback, schema snapshots, offline CI generation, pre-deploy impact analysis, multi-database support, and a full CLI for managing the complete migration lifecycle from init through production rollbacks.',
    tags: ['SQLAlchemy', 'FastAPI', 'PostgreSQL', '5 dialects'],
    links: [
      { label: 'GitHub', href: 'https://github.com/emiliano-go/DBWarden' },
      { label: 'PyPI', href: 'https://pypi.org/project/dbwarden/' },
    ],
  },
];
---

<section id="projects" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0">

    <div class="flex items-center gap-4 mb-10">
      <h2 class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap" data-i18n="projects.heading">
        Projects
      </h2>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <!-- DBWarden — featured card -->
    {projects.map((p) => (
      <div class="dbwarden-card relative border border-(--color-border) border-l-[3px] border-l-(--color-accent-dim) mb-px bg-(--color-surface) transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
        <div id="dbwarden-card-stars" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
        <div class="p-7 relative z-10">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <div class="flex items-start justify-between mb-2">
                <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">{p.tag}</p>
              </div>
              <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold uppercase tracking-wide text-(--color-text-head) mb-3">{p.name}</h2>
              <p class="text-xs leading-[1.75] text-(--color-text-muted) mb-5 max-w-[520px]" data-i18n="projects.dbwarden.desc">{p.desc}</p>
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="flex flex-wrap gap-2">
                  {p.tags.map(t => (
                    <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
                  ))}
                </div>
                <div class="flex flex-wrap gap-3 shrink-0">
                  {p.links.map(link => (
                    <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
            <div id="dbwarden-terminal" class="hidden md:block w-full border border-(--color-border) rounded bg-(--color-bg) overflow-hidden self-start">
              <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2" data-i18n="projects.terminal">terminal</span>
              </div>
              <div id="terminal-content" class="px-4 py-3 w-full text-[11px] leading-[1.9] font-mono text-(--color-text-muted) h-[300px] overflow-x-auto whitespace-nowrap"></div>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Small cards: schemap + Site Twilight -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle) mt-px">
      <!-- schemap -->
      <div class="bg-(--color-surface) flex transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
        <div class="p-5 pb-4 flex flex-col w-full">
          <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">Python Package</p>
          <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-2">schemap</h3>
          <p class="text-xs leading-[1.7] text-(--color-text-muted) flex-1" data-i18n="projects.schemap.desc">Automatic Pydantic v2 schemas from SQLAlchemy 2.0 ORM models.</p>
          <div class="flex flex-wrap items-end justify-between gap-4 mt-auto pt-3">
            <div class="flex flex-wrap gap-2">
              {['Pydantic v2', 'SQLAlchemy 2.0'].map(t => (
                <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
              ))}
            </div>
            <a href="/projects#schemap" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200" data-i18n="projects.details" data-i18n-html>
              Details <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">→</span>
            </a>
          </div>
        </div>
      </div>
      <!-- vigil -->
      <div class="bg-(--color-surface) flex transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
        <div class="p-5 pb-4 flex flex-col w-full">
          <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">Prefect Flow</p>
          <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-2">vigil</h3>
          <p class="text-xs leading-[1.7] text-(--color-text-muted) flex-1" data-i18n="projects.vigil.desc">Personal GitHub activity monitoring workflow built with Prefect. Fetches events, commits, and PR activity, then stores structured records in ClickHouse.</p>
          <div class="flex flex-wrap items-end justify-between gap-4 mt-auto pt-3">
            <div class="flex flex-wrap gap-2">
              {['Python', 'Prefect', 'PyGithub', 'ClickHouse'].map(t => (
                <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
              ))}
            </div>
            <a href="https://github.com/emiliano-go/vigil" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
              GitHub <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- View all -->
    <div class="flex justify-center mt-px">
      <a href="/projects" class="group w-full flex items-center justify-center gap-1.5 text-[13px] px-4 py-3 border border-(--color-border-subtle) bg-(--color-surface) hover:bg-(--color-bg) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200" data-i18n="projects.viewall" data-i18n-html>
        View all projects <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">↗</span>
      </a>
    </div>

  </div>
</section>

<script>
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const content = document.getElementById('terminal-content');
      if (content) {
        content.innerHTML = `
          <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden init</div>
          <div class="terminal-line">Initialized DBWarden project structure</div>
          <div class="terminal-line">Created migrations directory</div>
          <div class="terminal-line">Created dbwarden.py</div>
          <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden migrate</div>
          <div class="terminal-line">[DBWarden] Applying migrations...</div>
          <div class="terminal-line">[DBWarden] All migrations applied. Pending: 0</div>
          <div class="terminal-line" style="margin-top:4px"><span style="color:var(--color-accent-dim);animation:terminal-blink 1s step-end infinite">▊</span></div>`;
      }
      return;
    }

    const content = document.getElementById('terminal-content');
    if (!content) return;

    const sessions = [
      [
        { cmd: 'dbwarden init', output: ['Initialized DBWarden project structure', 'Created migrations directory', 'Created dbwarden.py'] },
        { cmd: 'dbwarden config', output: ['  Primary (sqlite)     sqlite:///./app.db', '  Migrations:          migrations/primary'] },
      ],
      [
        { cmd: 'dbwarden make-migrations "create users table"', output: ['Generated changes:', '  + CREATE TABLE users', '  + CREATE TABLE posts', 'Created: primary__0001_create_core_tables.sql'] },
      ],
      [
        { cmd: 'dbwarden migrate', output: ['[DBWarden] Applying primary__0001_create_core_tables...', '[DBWarden] Migration applied (42ms)'] },
        { cmd: 'dbwarden status', output: ['  Applied:  1', '  Pending:  0', '  Status:   up-to-date'] },
      ],
    ];

    function sleep(ms) {
      return new Promise(r => setTimeout(r, ms));
    }

    function typeChars(parent, text, base, range) {
      return new Promise(resolve => {
        let i = 0;
        function next() {
          if (i >= text.length) { resolve(); return; }
          const span = document.createElement('span');
          span.textContent = text[i];
          parent.appendChild(span);
          i++;
          setTimeout(next, base + Math.random() * range);
        }
        next();
      });
    }

    function addCmdLine() {
      const line = document.createElement('div');
      line.className = 'terminal-line';
      const prompt = document.createElement('span');
      prompt.className = 'text-(--color-accent-dim)';
      prompt.textContent = '$';
      line.appendChild(prompt);
      content.appendChild(line);
      return line;
    }

    function addOutputLine(text) {
      const line = document.createElement('div');
      line.className = 'terminal-line';
      line.textContent = text;
      content.appendChild(line);
    }

    (async () => {
        await sleep(400);

      while (true) {
        for (const block of sessions) {
          for (let i = 0; i < block.length; i++) {
            const entry = block[i];
            const isLast = i === block.length - 1;

            const cmdLine = addCmdLine();
            await typeChars(cmdLine, ' ' + entry.cmd, 50, 70);
            await sleep(300 + Math.random() * 250);

            for (const out of entry.output) {
              await sleep(120 + Math.random() * 80);
              addOutputLine(out);
            }

            if (isLast) {
              await sleep(1000 + Math.random() * 1000);
            } else {
              await sleep(800 + Math.random() * 400);
            }
          }

          const clearLine = addCmdLine();
          await typeChars(clearLine, ' clear', 50, 70);
          await sleep(2000);
          content.innerHTML = '';
          await sleep(600);
        }

        const cursorLine = document.createElement('div');
        cursorLine.className = 'terminal-line';
        const cursor = document.createElement('span');
        cursor.textContent = '▊';
        cursor.style.color = 'var(--color-accent-dim)';
        cursor.style.animation = 'terminal-blink 1s step-end infinite';
        cursorLine.appendChild(cursor);
        content.appendChild(cursorLine);
        await sleep(1500 + Math.random() * 500);
        content.innerHTML = '';
        await sleep(500);
      }
    })();
  })();
</script>

<script>
  (() => {
    const container = document.getElementById('dbwarden-card-stars');
    if (!container) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const stars = [];
    const minDist = 3;
    const maxStars = 150;

    for (let i = 0; i < maxStars; i++) {
      let placed = false;
      for (let attempt = 0; attempt < 80; attempt++) {
        const x = Math.random() * 100;
        const y = Math.random() * 100;
        if (!stars.some(s => Math.hypot(s.x - x, s.y - y) < minDist)) {
          stars.push({ x, y });
          placed = true;
          break;
        }
      }
      if (!placed) break;
    }

    for (const pos of stars) {
      const star = document.createElement('span');
      const size = 1 + Math.random() * 1.5;
      star.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        background: var(--color-star);
        border-radius: 50%;
        left: ${pos.x}%;
        top: ${pos.y}%;
        opacity: 0;
        will-change: transform, opacity;
      `;
      container.appendChild(star);
      const driftTargetX = Math.random() * 100;
      const driftTargetY = Math.random() * 100;
      star.__data = {
        twinkleSpeed: 0.6 + Math.random() * 1.5,
        twinklePhase: Math.random() * Math.PI * 2,
        minOpacity: 0,
        maxOpacity: 0.3 + Math.random() * 0.5,
        size: size,
        originX: pos.x,
        originY: pos.y,
        driftX: 0,
        driftY: 0,
        targetX: driftTargetX,
        targetY: driftTargetY,
        driftTimer: 0,
      };
    }

    let mouseX = 0, mouseY = 0;
    let currentX = 0, currentY = 0;

    document.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width - 0.5;
      mouseY = (e.clientY - rect.top) / rect.height - 0.5;
    });

    function animate() {
      currentX += (mouseX - currentX) * 0.04;
      currentY += (mouseY - currentY) * 0.04;

      const time = Date.now() / 1000;
      const dt = 1/60;

      const starEls = container.children;
      for (let i = 0; i < starEls.length; i++) {
        const el = starEls[i];
        const d = el.__data;

        d.driftTimer += dt;
        if (d.driftTimer > 3 + Math.random() * 4) {
          d.targetX = Math.random() * 100;
          d.targetY = Math.random() * 100;
          d.driftTimer = 0;
        }

        d.driftX += (d.targetX - (d.originX + d.driftX)) * 0.004;
        d.driftY += (d.targetY - (d.originY + d.driftY)) * 0.004;

        const parallaxX = currentX * 20 * d.size;
        const parallaxY = currentY * 20 * d.size;

        const twinkle = Math.sin(time * d.twinkleSpeed + d.twinklePhase);
        const opacity = d.minOpacity + (twinkle + 1) / 2 * (d.maxOpacity - d.minOpacity);

        const px = d.driftX + parallaxX;
        const py = d.driftY + parallaxY;

        el.style.transform = `translate(${px}px, ${py}px)`;
        el.style.opacity = Math.max(0, Math.min(1, opacity));
        el.style.left = `${d.originX}%`;
        el.style.top = `${d.originY}%`;
      }

      requestAnimationFrame(animate);
    }

    animate();
  })();
</script>

<style>
  .dbwarden-card {
    animation: border-pulse 3s ease-in-out infinite;
  }

  @keyframes border-pulse {
    0%, 100% { border-left-color: #3a6e5a; }
    50% { border-left-color: #5a9e8a; }
  }
</style>
