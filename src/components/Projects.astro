---

const projects = [
  {
    tag: 'Python Package · PyPI',
    name: 'DBWarden',
    desc: 'DBWarden is a SQL-first migration system for SQLAlchemy that replaces Python-based migration workflows with explicit, reviewable SQL generated directly from your models. No migration runtime, no generated Python scripts. Built-in rollback, schema snapshots, offline CI generation, pre-deploy impact analysis, multi-database support, and a full CLI for managing the complete migration lifecycle from init through production rollbacks.',
    tags: ['SQLAlchemy', 'FastAPI', 'PostgreSQL', '5 dialects'],
    links: [
      { label: 'GitHub', href: 'https://github.com/emiliano-go/DBWarden' },
      { label: 'PyPI', href: 'https://pypi.org/project/dbwarden/' },
    ],
  },
];
---

<section id="projects" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

    <div data-reveal data-delay="0" class="flex items-center gap-4 mb-10">
      <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
        Projects
      </span>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <!-- DBWarden — featured card -->
    {projects.map((p) => (
      <div data-reveal data-delay="0.1" class="border border-(--color-border-subtle) mb-px bg-(--color-surface) transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
        <div class="p-7">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <div class="flex items-start justify-between mb-2">
                <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">{p.tag}</p>
              </div>
              <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold uppercase tracking-wide text-(--color-text-head) mb-3">{p.name}</h2>
              <p class="text-xs leading-[1.75] text-(--color-text-muted) mb-5 max-w-[520px]">{p.desc}</p>
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="flex flex-wrap gap-2">
                  {p.tags.map(t => (
                    <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
                  ))}
                </div>
                <div class="flex flex-wrap gap-3 shrink-0">
                  {p.links.map(link => (
                    <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
            <div id="dbwarden-terminal" class="border border-(--color-border-subtle) rounded bg-(--color-bg) overflow-hidden self-start">
              <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2">terminal</span>
              </div>
              <div id="terminal-content" class="px-4 py-3 text-[11px] leading-[1.9] font-mono text-(--color-text-muted) h-[202px] overflow-y-auto"></div>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Small cards: schemap + Site Twilight -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle) mt-px">
      <!-- schemap -->
      <div data-reveal data-delay="0.15" class="bg-(--color-surface) flex transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
        <div class="p-5 pb-4 flex flex-col w-full">
          <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">Python Package</p>
          <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-2">schemap</h3>
          <p class="text-xs leading-[1.7] text-(--color-text-muted) flex-1">Automatic Pydantic v2 schemas from SQLAlchemy 2.0 ORM models.</p>
          <div class="flex flex-wrap items-end justify-between gap-4 mt-auto pt-3">
            <div class="flex flex-wrap gap-2">
              {['Pydantic v2', 'SQLAlchemy 2.0'].map(t => (
                <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
              ))}
            </div>
            <a href="/projects#schemap" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
              Details <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">→</span>
            </a>
          </div>
        </div>
      </div>
      <!-- Site Twilight -->
      <div data-reveal data-delay="0.2" class="bg-(--color-surface) flex transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
        <div class="p-5 pb-4 flex flex-col w-full">
          <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">Web App</p>
          <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-2">Site Twilight</h3>
          <p class="text-xs leading-[1.7] text-(--color-text-muted) flex-1">Internal web system for SCP:RP roleplay environment management.</p>
          <div class="flex flex-wrap items-end justify-between gap-4 mt-auto pt-3">
            <div class="flex flex-wrap gap-2">
              {['Django', 'Vue', 'RBAC'].map(t => (
                <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
              ))}
            </div>
            <a href="https://site-twilight.com" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
              Visit site <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- View all -->
    <div data-reveal data-delay="0.25" class="flex justify-center mt-px">
      <a href="/projects" class="group w-full flex items-center justify-center gap-1.5 text-[13px] px-4 py-3 border border-(--color-border-subtle) bg-(--color-surface) hover:bg-(--color-bg) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
        View all projects <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">↗</span>
      </a>
    </div>

  </div>
</section>

<script>
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const content = document.getElementById('terminal-content');
    if (!content) return;

    const sessions = [
      [
        { cmd: 'dbwarden init', output: ['Initialized DBWarden project structure', 'Created migrations directory', 'Created dbwarden.py'] },
        { cmd: 'dbwarden config', output: ['Configuration:', '  Databases:', '    primary (default):', '      Type: sqlite', '      Sync URL: sqlite:///./app.db'] },
      ],
      [
        { cmd: 'dbwarden make-migrations "create users table"', output: ['Generated changes:', '  + CREATE TABLE users', '  + CREATE TABLE posts', '', 'Created: primary__0001_create_core_tables.sql'] },
        { cmd: 'dbwarden migrate', output: ['[DBWarden] Applying primary__0001_create_core_tables...', '[DBWarden] Migration applied successfully (42ms)', '[DBWarden] All migrations applied. Pending: 0'] },
      ],
      [
        { cmd: 'dbwarden status', output: ['Database: primary', '  Applied:  1', '  Pending:  0', '  Status:   up-to-date'] },
      ],
    ];

    function sleep(ms) {
      return new Promise(r => setTimeout(r, ms));
    }

    function typeChars(parent, text, base, range) {
      return new Promise(resolve => {
        let i = 0;
        function next() {
          if (i >= text.length) { resolve(); return; }
          const span = document.createElement('span');
          span.textContent = text[i];
          parent.appendChild(span);
          i++;
          setTimeout(next, base + Math.random() * range);
        }
        next();
      });
    }

    function addCmdLine() {
      const line = document.createElement('div');
      line.className = 'terminal-line';
      const prompt = document.createElement('span');
      prompt.className = 'text-(--color-accent-dim)';
      prompt.textContent = '$';
      line.appendChild(prompt);
      content.appendChild(line);
      return line;
    }

    function addOutputLine(text) {
      const line = document.createElement('div');
      line.className = 'terminal-line';
      line.textContent = text;
      content.appendChild(line);
    }

    (async () => {
      await sleep(1400);

      while (true) {
        for (const block of sessions) {
          for (let i = 0; i < block.length; i++) {
            const entry = block[i];
            const isLast = i === block.length - 1;

            const cmdLine = addCmdLine();
            await typeChars(cmdLine, ' ' + entry.cmd, 50, 70);
            await sleep(300 + Math.random() * 250);

            for (const out of entry.output) {
              await sleep(120 + Math.random() * 80);
              addOutputLine(out);
            }

            if (isLast) {
              await sleep(1000 + Math.random() * 1000);
            } else {
              await sleep(800 + Math.random() * 400);
            }
          }

          const clearLine = addCmdLine();
          await typeChars(clearLine, ' clear', 50, 70);
          await sleep(400);
          content.innerHTML = '';
          await sleep(600);
        }

        const cursorLine = document.createElement('div');
        cursorLine.className = 'terminal-line';
        const cursor = document.createElement('span');
        cursor.textContent = '▊';
        cursor.style.color = 'var(--color-accent-dim)';
        cursor.style.animation = 'terminal-blink 1s step-end infinite';
        cursorLine.appendChild(cursor);
        content.appendChild(cursorLine);
        await sleep(2500 + Math.random() * 1000);
        content.innerHTML = '';
        await sleep(500);
      }
    })();
  })();
</script>
