---

const projects = [
  {
    tag: 'Python Package · PyPI',
    name: 'DBWarden',
    desc: 'DBWarden is a SQL-first migration system for SQLAlchemy that replaces Python-based migration workflows with explicit, reviewable SQL generated directly from your models. No migration runtime, no generated Python scripts. Built-in rollback, schema snapshots, offline CI generation, and pre-deploy impact analysis.',
    tags: ['SQLAlchemy', 'FastAPI', 'PostgreSQL', '5 dialects'],
    links: [
      { label: 'GitHub', href: 'https://github.com/emiliano-go/DBWarden' },
      { label: 'PyPI', href: 'https://pypi.org/project/dbwarden/' },
    ],
  },
];
---

<section id="projects" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

    <div data-reveal data-delay="0" class="flex items-center gap-4 mb-10">
      <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
        Projects
      </span>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <!-- DBWarden — featured card -->
    {projects.map((p) => (
      <div data-reveal data-delay="0.1" class="border border-(--color-border-subtle) mb-px bg-(--color-surface)">
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <div class="flex items-start justify-between mb-2">
                <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">{p.tag}</p>
              </div>
              <h2 class="font-[family-name:var(--font-display)] text-3xl font-bold uppercase tracking-wide text-(--color-text-head) mb-3">{p.name}</h2>
              <p class="text-xs leading-[1.75] text-(--color-text-muted) mb-5 max-w-[520px]">{p.desc}</p>
              <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="flex flex-wrap gap-2">
                  {p.tags.map(t => (
                    <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
                  ))}
                </div>
                <div class="flex flex-wrap gap-3 shrink-0">
                  {p.links.map(link => (
                    <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
            <div class="border border-(--color-border-subtle) rounded bg-(--color-bg) overflow-hidden self-start">
              <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2">terminal</span>
              </div>
              <div class="px-4 py-3 text-[11px] leading-[1.9] font-mono text-(--color-text-muted)">
                <div><span class="text-(--color-accent-dim)">$</span> dbwarden init</div>
                <div><span class="text-(--color-accent-dim)">$</span> dbwarden make-migrations <span class="text-(--color-text-dim)">"create users table"</span></div>
                <div><span class="text-(--color-accent-dim)">$</span> dbwarden migrate</div>
                <div><span class="text-(--color-accent-dim)">$</span> dbwarden status</div>
                <div><span class="text-(--color-accent-dim)">$</span> dbwarden rollback</div>
                <div><span class="text-(--color-accent-dim)">$</span> dbwarden history</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Small cards: schemap + Site Twilight -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle) mt-px">
      <!-- schemap -->
      <div data-reveal data-delay="0.15" class="bg-(--color-surface) flex">
        <div class="p-5 pb-4 flex flex-col w-full">
          <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">Python Package</p>
          <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-2">schemap</h3>
          <p class="text-xs leading-[1.7] text-(--color-text-muted) flex-1">Automatic Pydantic v2 schemas from SQLAlchemy 2.0 ORM models.</p>
          <div class="flex flex-wrap items-end justify-between gap-4 mt-auto pt-3">
            <div class="flex flex-wrap gap-2">
              {['Pydantic v2', 'SQLAlchemy 2.0'].map(t => (
                <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
              ))}
            </div>
            <a href="/projects#schemap" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
              Details →
            </a>
          </div>
        </div>
      </div>
      <!-- Site Twilight -->
      <div data-reveal data-delay="0.2" class="bg-(--color-surface) flex">
        <div class="p-5 pb-4 flex flex-col w-full">
          <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">Web App</p>
          <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-2">Site Twilight</h3>
          <p class="text-xs leading-[1.7] text-(--color-text-muted) flex-1">Internal web system for SCP:RP roleplay environment management.</p>
          <div class="flex flex-wrap items-end justify-between gap-4 mt-auto pt-3">
            <div class="flex flex-wrap gap-2">
              {['Django', 'Vue', 'RBAC'].map(t => (
                <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
              ))}
            </div>
            <a href="https://site-twilight.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
              Visit site ↗
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- View all -->
    <div data-reveal data-delay="0.25" class="flex justify-center mt-px">
      <a href="/projects" class="w-full flex items-center justify-center gap-1.5 text-[13px] px-4 py-3 border border-(--color-border-subtle) bg-(--color-surface) hover:bg-(--color-bg) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
        View all projects ↗
      </a>
    </div>

  </div>
</section>
