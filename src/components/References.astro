---
interface ReferenceItem {
  name: string;
  title: string;
  company: string;
  relationship: string;
  linkedin: string;
}

const references: ReferenceItem[] = [
  {
    name: 'Igor Benav',
    title: 'Founder',
    company: 'Benav Labs',
    relationship: 'Co-maintainer, 2025 - Present',
    linkedin: 'https://www.linkedin.com/in/igor-benav/',
  },
  {
    name: 'Carlos A. Planchon',
    title: 'Technical Leader',
    company: 'Busco Jobs',
    relationship: 'Colleague, 2023 - Present',
    linkedin: 'https://www.linkedin.com/in/carlosplanchon/',
  },
  {
    name: 'Maximiliano Schmidt',
    title: 'Full-Stack Developer',
    company: 'Casas Y Mas',
    relationship: 'Colleague, 2026 - Present',
    linkedin: 'https://www.linkedin.com/in/maximiliano-schmidt/',
  },
];
import { createT } from '../i18n';
const t = createT(Astro.props.lang);
---

<section id="references" class="py-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0">

    <div class="flex items-center gap-4 mb-10">
      <h2 class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">{t("refs.heading")}</h2>
      <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle)">
      {references.map((ref, i) => (
        <div
          class="bg-(--color-surface) flex"
        >
          <div class="p-4 flex flex-col w-full">
            <h3 class="font-[family-name:var(--font-display)] text-base font-bold uppercase tracking-wide text-(--color-text-head) mb-0.5">{ref.name}</h3>
            <p class="text-xs text-(--color-text-dim) leading-snug">
              {ref.title}, <span class="text-(--color-text-muted)">{ref.company}</span>
            </p>
            <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-accent-dim) mt-2 mb-3">{ref.relationship}</p>
            <a
              href={ref.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="self-end inline-flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200"
            >{t("refs.linkedin")}</a>
          </div>
        </div>
      ))}
    </div>
    </div>

  </div>
</section>
