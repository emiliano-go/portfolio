---
---

<section class="hero-section relative min-h-screen flex items-center border-b border-(--color-border-subtle) overflow-hidden">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px] relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-end">

      <!-- Left: headline -->
      <div>
        <p
          id="hero-tag"
          class="text-[10px] uppercase tracking-[0.1em] text-(--color-accent) mb-4 font-semibold opacity-0"
        >
          Backend Engineer · Data Scientist
        </p>

        <!-- Liquid glass heading -->
        <h1
          id="hero-title"
          class="glass-text relative z-10 font-[family-name:var(--font-display)] text-[clamp(44px,5.5vw,72px)] font-bold uppercase leading-[0.92] tracking-wide opacity-0 mb-6"
          style="transform: translateY(24px)"
        >
          Building<br />
          systems that<br />
          <span class="text-(--color-text-dim)">handle</span><br />
          real data.
        </h1>

        <p
          id="hero-desc"
          class="text-sm leading-relaxed text-(--color-text-muted) max-w-[360px] opacity-0"
          style="transform: translateY(12px)"
        >
          Python developer focused on data pipelines, ETL infrastructure, and backend architecture.
          Based in Montevideo, Uruguay. Open to interesting problems.
        </p>
      </div>

      <!-- Right: stats -->
      <div id="hero-stats" class="flex flex-col gap-0 opacity-0">
        <div class="flex items-baseline justify-between py-4 border-t border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide">~2K</span>
          <span class="text-xs text-(--color-text-muted)">stars on maintained OSS</span>
        </div>
        <div class="flex items-baseline justify-between py-4 border-t border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide">5</span>
          <span class="text-xs text-(--color-text-muted)">packages on PyPI</span>
        </div>
        <div class="flex items-baseline justify-between py-4 border-t border-b border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide flex items-center gap-2">
            <span id="dot" class="inline-block w-2 h-2 rounded-full bg-(--color-accent) opacity-0"></span>
            UY
          </span>
          <span class="text-xs text-(--color-text-muted)">Montevideo, Uruguay</span>
        </div>
      </div>

    </div>
  </div>

  <!-- Mouse scroll indicator -->
  <div class="mouse-indicator absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center">
    <svg width="20" height="38" viewBox="0 0 20 38" fill="none" class="text-(--color-text-dim)">
      <rect x="1.5" y="1.5" width="17" height="26" rx="8.5" stroke="currentColor" stroke-width="1.5"/>
      <line x1="10" y1="6" x2="10" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="wheel-line"/>
      <path d="M10 31l-4-4 4 4 4-4-4 4z" fill="currentColor"/>
    </svg>
  </div>
</section>

<style>
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 25% 30%, color-mix(in srgb, var(--color-accent) 12%, transparent) 0%, transparent 100%),
      radial-gradient(ellipse 50% 30% at 75% 60%, color-mix(in srgb, var(--color-text-dim) 8%, transparent) 0%, transparent 100%),
      radial-gradient(circle 0.7px at 50% 50%, var(--color-text-dim) 0.7px, transparent 0.7px);
    background-size: 100% 100%, 100% 100%, 20px 20px;
    pointer-events: none;
  }

  .glass-text {
    background: linear-gradient(
      135deg,
      var(--color-text-head) 0%,
      color-mix(in srgb, var(--color-text-head) 70%, transparent) 40%,
      color-mix(in srgb, var(--color-text-head) 85%, white) 50%,
      color-mix(in srgb, var(--color-text-head) 70%, transparent) 60%,
      var(--color-text-head) 100%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: glass-text-shine 6s ease-in-out infinite;
  }

  @keyframes glass-text-shine {
    0%, 100% { background-position: 200% 0; }
    50% { background-position: -100% 0; }
  }

  .mouse-indicator {
    animation: mouse-bounce 2.5s ease-in-out infinite;
  }

  .wheel-line {
    animation: wheel-scroll 2.5s ease-in-out infinite;
  }

  @keyframes mouse-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(4px); }
  }

  @keyframes wheel-scroll {
    0%, 100% { y1: 6; y2: 12; opacity: 1; }
    50% { y1: 12; y2: 18; opacity: 0.3; }
  }
</style>

<script>
  import { animate } from 'motion';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    animate('#hero-tag', { opacity: [0, 1] }, { duration: 0.5, delay: 0.15, easing: 'ease-out' });
    animate('#hero-title', { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0px)'] }, { duration: 0.7, delay: 0.3, easing: [0.25, 0.46, 0.45, 0.94] });
    animate('#hero-desc', { opacity: [0, 1], transform: ['translateY(12px)', 'translateY(0px)'] }, { duration: 0.6, delay: 0.55, easing: 'ease-out' });
    animate('#hero-stats', { opacity: [0, 1] }, { duration: 0.6, delay: 0.7, easing: 'ease-out' });
    animate('#dot', { opacity: [0, 1] }, { duration: 0.4, delay: 0.9 }).then(() => {
      animate('#dot', { opacity: [1, 0.25, 1] }, { duration: 2.8, repeat: Infinity, easing: 'ease-in-out' });
    });
  } else {
    ['#hero-tag', '#hero-title', '#hero-desc', '#hero-stats', '#dot'].forEach((sel) => {
      const el = document.querySelector(sel) as HTMLElement | null;
      if (el) { el.style.opacity = '1'; el.style.transform = 'none'; }
    });
  }
</script>
