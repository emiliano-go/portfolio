---
let vigilData = { latestCommit: null };
try {
  const mod = await import('../data/vigil-data.json');
  vigilData = mod.default || mod;
} catch {}
const latest = vigilData?.latestCommit || null;
const isPrivateRepo = latest && (vigilData?.privateRepos || []).includes(latest.repo);
const latestTitle = latest?.message ? latest.message.replace(/\n.*$/, '').trim() : '';
---

<section class="hero-section relative min-h-screen flex items-center border-b border-(--color-border-subtle) overflow-hidden">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px] relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-end">

      <!-- Left: headline -->
      <div>
        <p
          id="hero-tag"
          class="text-[10px] uppercase tracking-[0.1em] text-(--color-accent) mb-4 font-semibold"
        >
          <span data-i18n="hero.tagline">Backend Engineer · Data Scientist</span>
        </p>

        <!-- Liquid glass heading -->
        <h1
          id="hero-title"
          class="font-[family-name:var(--font-display)] text-[clamp(44px,5.5vw,72px)] font-bold uppercase leading-[0.92] tracking-wide mb-6"
        >
          <span class="glass-word" style="--i: 0" data-i18n="hero.title.line1">Building</span><br />
          <span class="glass-word" style="--i: 1" data-i18n="hero.title.line2">systems</span>
          <span class="glass-word" style="--i: 2" data-i18n="hero.title.line3">that</span><br />
          <span class="glass-word dim" style="--i: 3" data-i18n="hero.title.line4">handle</span><br />
          <span class="glass-word" style="--i: 4" data-i18n="hero.title.line5">real</span>
          <span class="glass-word" style="--i: 5" data-i18n="hero.title.line6">data.</span>
        </h1>

        <p
          id="hero-desc"
          class="text-sm leading-relaxed text-(--color-text-muted) max-w-[360px]"
        >
          <span data-i18n="hero.desc">Python developer focused on data pipelines, ETL infrastructure, and backend architecture.
          Based in Montevideo, Uruguay. Open to interesting problems.</span>
        </p>
      </div>

      <!-- Right: stats -->
      <div id="hero-stats" class="flex flex-col gap-0">
        {latest && (
        <div class="flex items-baseline justify-between py-2 border-t border-(--color-border-subtle) hero-commit-line">
          <span class="text-[10px] font-mono text-(--color-text-dim) tracking-wide truncate max-w-[220px]">
            <span data-i18n="hero.latestCommit">Latest commit made in:</span>
            {isPrivateRepo ? (
            <span data-i18n="hero.privateRepo">a private repo</span>
            ) : (
            <span title={latestTitle}>{latest.repo}</span>
            )}
          </span>
          <time datetime={latest.committed_at} class="text-[10px] text-(--color-text-dim) whitespace-nowrap vigil-timeago">{latest.committed_at}</time>
        </div>
        )}
        <div class="flex items-baseline justify-between py-4 border-t border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide">~2K</span>
          <span class="text-xs text-(--color-text-muted)" data-i18n="hero.stat.stars">stars on maintained OSS</span>
        </div>
        <div class="flex items-baseline justify-between py-4 border-t border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide">6</span>
          <span class="text-xs text-(--color-text-muted)" data-i18n="hero.stat.pypi">packages on PyPI</span>
        </div>
        <div class="flex items-baseline justify-between py-4 border-t border-b border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide flex items-center gap-2">
            <span id="dot" class="inline-block w-2 h-2 rounded-full bg-(--color-accent)"></span>
            UY
          </span>
          <span class="text-xs text-(--color-text-muted)" data-i18n="hero.stat.location">Montevideo, Uruguay</span>
        </div>
      </div>

    </div>
  </div>

  <!-- Mouse scroll indicator -->
  <div class="mouse-indicator absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center">
    <svg width="20" height="38" viewBox="0 0 20 38" fill="none" class="text-(--color-text-dim)">
      <rect x="1.5" y="1.5" width="17" height="26" rx="8.5" stroke="currentColor" stroke-width="1.5"/>
      <line x1="10" y1="6" x2="10" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="wheel-line"/>
      <path d="M10 31l-4-4 4 4 4-4-4 4z" fill="currentColor"/>
    </svg>
  </div>
</section>

<style>
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 25% 30%, color-mix(in srgb, var(--color-accent) 12%, transparent) 0%, transparent 100%),
      radial-gradient(ellipse 50% 30% at 75% 60%, color-mix(in srgb, var(--color-text-dim) 8%, transparent) 0%, transparent 100%),
      radial-gradient(circle 0.7px at 50% 50%, var(--color-star) 0.7px, transparent 0.7px);
    background-size: 100% 100%, 100% 100%, 20px 20px;
    pointer-events: none;
  }

  .glass-word {
    display: inline-block;
    background: linear-gradient(
      105deg,
      color-mix(in srgb, var(--color-text-head) 100%, white) 0%,
      color-mix(in srgb, var(--color-text-head) 70%, white) 35%,
      color-mix(in srgb, var(--color-text-head) 90%, white) 50%,
      color-mix(in srgb, var(--color-text-head) 70%, white) 65%,
      color-mix(in srgb, var(--color-text-head) 100%, white) 100%
    );
    background-size: 200% 100%;
    background-position: -100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: word-shine 4s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.1s);
  }

  .glass-word.dim {
    background: linear-gradient(
      105deg,
      color-mix(in srgb, var(--color-text-dim) 100%, white) 0%,
      color-mix(in srgb, var(--color-text-dim) 70%, white) 35%,
      color-mix(in srgb, var(--color-text-dim) 90%, white) 50%,
      color-mix(in srgb, var(--color-text-dim) 70%, white) 65%,
      color-mix(in srgb, var(--color-text-dim) 100%, white) 100%
    );
    background-size: 200% 100%;
    background-position: -100% 0;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: word-shine 4s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.1s);
  }

  @keyframes word-shine {
    0%, 100% { background-position: -100% 0; }
    45% { background-position: 200% 0; }
    55% { background-position: 200% 0; }
  }

  .mouse-indicator {
    animation: mouse-bounce 2.5s ease-in-out infinite;
    transition: opacity 0.4s ease;
  }

  .wheel-line {
    animation: wheel-scroll 2.5s ease-in-out infinite;
  }

  @keyframes mouse-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(4px); }
  }

  @keyframes wheel-scroll {
    0%, 100% { y1: 6; y2: 12; opacity: 1; }
    50% { y1: 12; y2: 18; opacity: 0.3; }
  }

  /* ── Entrance animations (replacing motion) ── */

  #hero-tag {
    opacity: 0;
    animation: hero-fade-in 0.5s ease-out 0.15s forwards;
  }

  #hero-title {
    opacity: 0;
    transform: translateY(24px);
    animation: hero-slide-up 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.3s forwards;
  }

  #hero-desc {
    opacity: 0;
    transform: translateY(12px);
    animation: hero-slide-up-small 0.6s ease-out 0.55s forwards;
  }

  #hero-stats {
    opacity: 0;
    animation: hero-fade-in 0.6s ease-out 0.7s forwards;
  }

  #dot {
    opacity: 0;
    animation:
      dot-appear 0.4s ease-out 0.9s forwards,
      dot-pulse 2.8s ease-in-out 1.3s infinite;
  }

  @keyframes hero-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes hero-slide-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes hero-slide-up-small {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes dot-appear {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  @media (prefers-reduced-motion: reduce) {
    #hero-tag,
    #hero-title,
    #hero-desc,
    #hero-stats,
    #dot {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

<script is:inline>
  (function() {
    let raf = null;
    var indicator = document.querySelector('.mouse-indicator');
    function onScroll() {
      if (raf) return;
      raf = requestAnimationFrame(function() {
        var faded = window.scrollY > 60;
        if (indicator) indicator.style.opacity = faded ? '0' : '1';
        raf = null;
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
  })();

  (function() {
    var els = document.querySelectorAll('.vigil-timeago');
    if (!els.length) return;
    function ago(iso) {
      var now = Date.now();
      var then = new Date(iso).getTime();
      var diff = now - then;
      if (diff < 60000) return 'just now';
      var mins = Math.floor(diff / 60000);
      if (mins < 60) return mins + 'm ago';
      var hrs = Math.floor(mins / 60);
      if (hrs < 24) return hrs + 'h ago';
      var days = Math.floor(hrs / 24);
      if (days < 7) return days + 'd ago';
      if (days < 30) return Math.floor(days / 7) + 'w ago';
      return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }
    for (var i = 0; i < els.length; i++) {
      els[i].textContent = ago(els[i].getAttribute('datetime'));
    }
  })();
</script>
