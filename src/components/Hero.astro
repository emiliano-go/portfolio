---
---

<section class="pt-24 pb-16 border-b border-(--color-border-subtle)">
  <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-end">

      <!-- Left: headline -->
      <div>
        <p
          id="hero-tag"
          class="text-[11px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-4 opacity-0"
        >
          Backend Engineer · Data Scientist
        </p>
        <h1
          id="hero-title"
          class="font-[family-name:var(--font-display)] text-[clamp(48px,6vw,76px)] font-bold uppercase leading-[0.92] tracking-wide text-(--color-text-head) mb-6 opacity-0"
          style="transform: translateY(24px)"
        >
          Building<br />
          systems that<br />
          <span class="text-(--color-text-dim)">handle</span><br />
          real data.
        </h1>
        <p
          id="hero-desc"
          class="text-[13px] leading-[1.8] text-(--color-text-muted) max-w-[360px] opacity-0"
          style="transform: translateY(12px)"
        >
          Python developer focused on data pipelines, ETL infrastructure, and backend architecture.
          Based in Montevideo, Uruguay. Open to interesting problems.
        </p>
      </div>

      <!-- Right: stats -->
      <div id="hero-stats" class="flex flex-col gap-0 opacity-0">
        <div class="flex items-baseline justify-between py-4 border-t border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide">~2K</span>
          <span class="text-xs text-(--color-text-muted)">stars on maintained OSS</span>
        </div>
        <div class="flex items-baseline justify-between py-4 border-t border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide">5</span>
          <span class="text-xs text-(--color-text-muted)">packages on PyPI</span>
        </div>
        <div class="flex items-baseline justify-between py-4 border-t border-b border-(--color-border-subtle)">
          <span class="font-[family-name:var(--font-display)] text-4xl font-bold text-(--color-text-head) tracking-wide flex items-center gap-2">
            <span id="dot" class="inline-block w-2 h-2 rounded-full bg-(--color-accent) opacity-0"></span>
            UY
          </span>
          <span class="text-xs text-(--color-text-muted)">Montevideo, Uruguay</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { animate } from 'motion';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    animate('#hero-tag', { opacity: [0, 1] }, { duration: 0.5, delay: 0.15, easing: 'ease-out' });
    animate('#hero-title', { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0px)'] }, { duration: 0.7, delay: 0.3, easing: [0.25, 0.46, 0.45, 0.94] });
    animate('#hero-desc', { opacity: [0, 1], transform: ['translateY(12px)', 'translateY(0px)'] }, { duration: 0.6, delay: 0.55, easing: 'ease-out' });
    animate('#hero-stats', { opacity: [0, 1] }, { duration: 0.6, delay: 0.7, easing: 'ease-out' });
    animate('#dot', { opacity: [0, 1] }, { duration: 0.4, delay: 0.9 }).then(() => {
      animate('#dot', { opacity: [1, 0.25, 1] }, { duration: 2.8, repeat: Infinity, easing: 'ease-in-out' });
    });
  } else {
    ['#hero-tag', '#hero-title', '#hero-desc', '#hero-stats', '#dot'].forEach((sel) => {
      const el = document.querySelector(sel) as HTMLElement | null;
      if (el) { el.style.opacity = '1'; el.style.transform = 'none'; }
    });
  }
</script>
