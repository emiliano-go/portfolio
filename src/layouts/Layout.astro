---
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/barlow-condensed/latin-600.css';
import '@fontsource/barlow-condensed/latin-700.css';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { createT } from '../i18n';
import Seo from '../components/Seo.astro';

export interface Props {
  lang: string;
  route?: string;
  title?: string;
  description?: string;
}

const { lang, route, title, description } = Astro.props;
const t = createT(lang);

const url = Astro.url;
const slug = url.pathname === '/' ? 'index' : url.pathname.replace(/^\//, '').replace(/\/$/, '') || 'index';
const pageTitle = title ?? t('meta.default.title');
const pageDesc = description ?? t('meta.default.desc');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <ClientRouter />
    <Seo route={route ?? Astro.url.pathname} fallbackTitle={title} fallbackDescription={description} extra={{ lang }} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://challenges.cloudflare.com" />
    <link rel="preconnect" href="https://blog.emiliano-go.com" />
    <link rel="prefetch" href="/projects" />
    <script>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (stored === 'light' || (!stored && prefersLight)) {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body class="bg-(--color-bg) font-[family-name:var(--font-body)] text-(--color-text-base) antialiased">
    <div id="i18n-wrapper" class="i18n-show">
      <slot />
    </div>
  </body>
</html>
