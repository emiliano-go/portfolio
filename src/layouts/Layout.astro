---
import '@fontsource/inter/latin-400.css';
import '@fontsource/inter/latin-500.css';
import '@fontsource/barlow-condensed/latin-600.css';
import '@fontsource/barlow-condensed/latin-700.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Emiliano G.O. - Backend Engineer & Data Scientist',
  description = 'Python developer focused on data pipelines, ETL infrastructure, and backend architecture. Based in Montevideo, Uruguay.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='12' fill='%23111616'/><text x='50' y='68' font-family='monospace' font-size='52' font-weight='bold' fill='%235a9e8a' text-anchor='middle'>&gt;_</text></svg>" />
    <link rel="prefetch" href="/projects" />
    <script>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (stored === 'light' || (!stored && prefersLight)) {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body class="bg-(--color-bg) font-[family-name:var(--font-body)] text-(--color-text-base) antialiased">
    <slot />
  </body>
</html>
