---
// Root projects redirect → default language
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Projects | Emiliano G.O.</title>
  <script>
    (function() {
      var stored = localStorage.getItem('lang');
      var browser = (navigator.language || '').slice(0, 2);
      var lang = stored || (browser === 'es' || browser === 'fr' ? browser : 'en');
      location.replace('/' + lang + '/projects');
    })();
  </script>
</head>
<body>
  <p><a href="/en/projects">Continue to Projects</a></p>
</body>
</html>
