---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Projects | Emiliano G.O.">
  <Nav />
  <main>

    <!-- ─── DBWarden — Dedicated Section ─── -->
    <section id="dbwarden" class="min-h-screen pt-24 pb-6 md:pt-28 md:pb-10 border-b border-(--color-border-subtle) flex flex-col justify-center relative" style="background: var(--color-bg);">
      <div id="dbwarden-stars" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px] relative z-10">

        <div class="flex items-center gap-4 mb-6">
          <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-accent) whitespace-nowrap">
            Featured Project
          </span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <!-- Title + desc on left, terminal on right -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 items-start">
          <div>
            <p class="text-[11px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-3">Python Package · PyPI</p>
            <h1 class="font-[family-name:var(--font-display)] text-[44px] md:text-[56px] font-bold uppercase leading-[0.92] tracking-wide text-(--color-text-head) mb-3">
              DBWarden
            </h1>
            <p class="text-lg md:text-xl text-(--color-text-bright) mb-6">The SQL-first database toolkit for SQLAlchemy.</p>
            <p class="text-[13px] leading-[1.8] text-(--color-text-muted) max-w-[640px] mb-6">
              DBWarden is a SQL-first migration system for SQLAlchemy that replaces Python-based migration workflows with explicit, reviewable SQL generated directly from your models. Unlike script-based migration tools, DBWarden does not introduce a migration runtime or require executing generated Python migration code. It produces plain SQL files that can be reviewed, versioned, and executed directly against any environment.
            </p>
            <!-- 2x2 link grid -->
            <div class="grid grid-cols-2 gap-3">
              <a href="https://github.com/emiliano-go/DBWarden" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                GitHub <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
              <a href="https://pypi.org/project/dbwarden/" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                PyPI <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
              <a href="https://dbwarden.emiliano-go.com/" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                Full documentation <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
              <a href="https://deepwiki.com/emiliano-go/DBWarden/" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                DeepWiki <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
            </div>
          </div>
          <div id="dbwarden-terminal" class="w-full border border-(--color-border) rounded bg-(--color-bg) overflow-hidden self-start">
            <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
              <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
              <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
              <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
              <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2">terminal</span>
            </div>
            <div id="terminal-content" class="px-4 py-3 w-full text-[11px] leading-[1.9] font-mono text-(--color-text-muted) h-[300px] overflow-x-auto whitespace-nowrap"></div>
          </div>
        </div>

        <!-- Feature grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-4">
          {[
            { title: 'SQL-first', desc: 'Migrations are plain SQL. No runtime required.' },
            { title: 'Rollback included', desc: 'Every migration carries upgrade + rollback SQL.' },
            { title: 'Schema snapshots', desc: 'Checksummed JSON after every migration for deterministic diffs.' },
            { title: 'Column-level diffing', desc: 'Type, nullability, default, and comment changes.' },
            { title: 'Impact analysis', desc: 'AST-based scan to detect breaking changes before deploy.' },
            { title: 'Offline mode', desc: 'Export model state, generate migrations anywhere, no DB needed.' },
            { title: 'FastAPI integration', desc: 'Startup validation, health checks, runtime lifecycle.' },
            { title: '5 DB dialects', desc: 'PostgreSQL, MySQL, MariaDB, SQLite, ClickHouse.' },
          ].map(f => (
            <div class="border border-(--color-border) bg-(--color-surface) p-4 transition-all duration-200 hover:bg-(--color-bg)">
              <p class="text-[11px] font-semibold text-(--color-text-bright) uppercase tracking-wide mb-1">{f.title}</p>
              <p class="text-[11px] leading-[1.6] text-(--color-text-muted)">{f.desc}</p>
            </div>
          ))}
        </div>

        <!-- Stats bar -->
        <div id="dbwarden-stats" class="flex flex-wrap justify-center gap-6 md:gap-10 py-3 px-3 border border-(--color-border) bg-(--color-surface) rounded">
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">12</span><span class="text-xs text-(--color-text-dim) ml-1.5">stars</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">829</span><span class="text-xs text-(--color-text-dim) ml-1.5">tests</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">31K+</span><span class="text-xs text-(--color-text-dim) ml-1.5">LOC</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">5</span><span class="text-xs text-(--color-text-dim) ml-1.5">DB dialects</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">15+</span><span class="text-xs text-(--color-text-dim) ml-1.5">CLI commands</span></div>
        </div>
      </div>
    </section>

    <!-- ─── schemap ─── -->
    <section id="schemap" class="py-16 border-b border-(--color-border-subtle)">
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

        <div class="flex items-center gap-4 mb-10">
          <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
            Python Package
          </span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <div class="border border-(--color-border-subtle) bg-(--color-surface) p-6 md:p-8 transition-all duration-300 hover:scale-[1.01] hover:bg-(--color-bg)">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
            <div>
              <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-2">PyPI</p>
              <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-bold uppercase tracking-wide text-(--color-text-head) mb-4">schemap</h2>
              <p class="text-[13px] leading-[1.8] text-(--color-text-muted) mb-4">
                Automatic Pydantic v2 schemas from SQLAlchemy 2.0 ORM models.
                Define your model once, schemap generates Create, Update, Public, and Full schemas automatically,
                with field-level type mapping, nullability handling, and configurable exclusions.
              </p>
              <p class="text-[13px] leading-[1.8] text-(--color-text-muted) mb-6">
                Supports <code class="text-[11px] px-1 py-[1px] bg-(--color-bg) border border-(--color-border-subtle) rounded">AutoBase</code> inheritance and <code class="text-[11px] px-1 py-[1px] bg-(--color-bg) border border-(--color-border-subtle) rounded">@auto_schema</code> decorator,
                with built-in TimestampMixin and SoftDeleteMixin. Eliminates repetitive schema boilerplate.
              </p>
              <div class="flex flex-wrap items-center gap-3">
                <div class="flex flex-wrap gap-2">
                  {['Pydantic v2', 'SQLAlchemy 2.0', 'PyPI'].map(t => (
                    <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
                  ))}
                </div>
                <div class="flex flex-wrap gap-3 shrink-0">
                  <a href="https://github.com/emiliano-go/schemap" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                    GitHub <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                  </a>
                </div>
              </div>
            </div>
            <div class="flex items-start self-stretch">
              <div class="w-full border border-(--color-border) rounded bg-(--color-bg) overflow-hidden self-stretch">
                <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
                  <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                  <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                  <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                  <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2">schemap.py</span>
                </div>
                <div class="px-4 py-3 text-[11px] leading-[1.9] font-mono text-(--color-text-muted) overflow-x-auto">
                  <div><span class="text-(--color-accent-dim)">@auto_schema</span></div>
                  <div><span class="text-(--color-text-dim)">class</span> <span class="text-(--color-text-head)">User</span>(Base):</div>
                  <div>    <span class="text-(--color-text-dim)">__tablename__</span> = <span class="text-(--color-accent-dim)">"users"</span></div>
                  <div>    id = Column(Integer, primary_key=<span class="text-(--color-accent-dim)">True</span>)</div>
                  <div>    name = Column(String(100))</div>
                  <div>    email = Column(String(255), unique=<span class="text-(--color-accent-dim)">True</span>)</div>
                  <div>&nbsp;</div>
                  <div><span class="text-(--color-text-dim)"># CreateUser, UpdateUser,</span></div>
                  <div><span class="text-(--color-text-dim)"># PublicUser,  FullUser</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PyPI Utilities ─── -->
    <section id="pypi-utils" class="py-16 border-b border-(--color-border-subtle)">
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

        <div class="flex items-center gap-4 mb-10">
          <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
            PyPI Utilities
          </span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <div class="border border-(--color-border-subtle) bg-(--color-surface)">
          <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-(--color-border-subtle)">
            <!-- seoslug -->
            <div class="p-6 flex flex-col">
              <div class="flex items-center gap-2 mb-2">
                <h3 class="font-[family-name:var(--font-display)] text-lg font-bold uppercase tracking-wide text-(--color-text-head)">seoslug</h3>
                <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">Python</span>
              </div>
              <p class="text-[11px] leading-[1.7] text-(--color-text-muted) flex-1 mb-4">
                Deterministic SEO payload generation: canonical URLs, Open Graph, Twitter Cards, and JSON-LD. Same input always produces the same output. Testable, cacheable, predictable.
              </p>
              <div class="flex flex-wrap gap-2 mt-auto">
                <a href="https://github.com/emiliano-go/seoslug" target="_blank" rel="noopener noreferrer" class="group text-[10px] px-2 py-[3px] border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">
                  GitHub <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
                <a href="https://pypi.org/project/seoslug/" target="_blank" rel="noopener noreferrer" class="group text-[10px] px-2 py-[3px] border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">
                  PyPI <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
              </div>
            </div>
            <!-- detrack -->
            <div class="p-6 flex flex-col">
              <div class="flex items-center gap-2 mb-2">
                <h3 class="font-[family-name:var(--font-display)] text-lg font-bold uppercase tracking-wide text-(--color-text-head)">detrack</h3>
                <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">Python</span>
              </div>
              <p class="text-[11px] leading-[1.7] text-(--color-text-muted) flex-1 mb-4">
                Strip tracking parameters from URLs. Deterministically. Zero dependencies.
                60+ default patterns, case-insensitive, pure functions, metadata returned.
              </p>
              <div class="flex flex-wrap gap-2 mt-auto">
                <a href="https://github.com/emiliano-go/detrack" target="_blank" rel="noopener noreferrer" class="group text-[10px] px-2 py-[3px] border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">
                  GitHub <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
                <a href="https://pypi.org/project/detrack/" target="_blank" rel="noopener noreferrer" class="group text-[10px] px-2 py-[3px] border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">
                  PyPI <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
              </div>
            </div>
            <!-- acrresolv -->
            <div class="p-6 flex flex-col">
              <div class="flex items-center gap-2 mb-2">
                <h3 class="font-[family-name:var(--font-display)] text-lg font-bold uppercase tracking-wide text-(--color-text-head)">acrresolv</h3>
                <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">Python</span>
              </div>
              <p class="text-[11px] leading-[1.7] text-(--color-text-muted) flex-1 mb-4">
                Acronym resolver for Python. Converts natural language phrases to acronyms.
                Zero dependencies, CLI and library usage. Being expanded with ML.
              </p>
              <div class="flex flex-wrap gap-2 mt-auto">
                <a href="https://github.com/emiliano-go/acrresolv" target="_blank" rel="noopener noreferrer" class="group text-[10px] px-2 py-[3px] border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">
                  GitHub <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
                <a href="https://pypi.org/project/acrresolv/" target="_blank" rel="noopener noreferrer" class="group text-[10px] px-2 py-[3px] border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">
                  PyPI <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── More Projects ─── -->
    <section id="more-projects" class="py-16 border-b border-(--color-border-subtle)">
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

        <div class="flex items-center gap-4 mb-10">
          <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
            More Projects
          </span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <div class="split-layout" id="split-layout">
          <div class="split-nav" role="tablist">
            <button class="split-btn active" data-target="0" role="tab" aria-selected="true">
              <span class="text-[9px] uppercase tracking-[0.12em] text-(--color-text-dim)">01</span>
              <span class="font-[family-name:var(--font-display)] text-sm font-bold uppercase tracking-wide text-(--color-text-head)">crxml</span>
            </button>
            <button class="split-btn" data-target="1" role="tab" aria-selected="false">
              <span class="text-[9px] uppercase tracking-[0.12em] text-(--color-text-dim)">02</span>
              <span class="font-[family-name:var(--font-display)] text-sm font-bold uppercase tracking-wide text-(--color-text-head)">vigil</span>
            </button>
            <button class="split-btn" data-target="2" role="tab" aria-selected="false">
              <span class="text-[9px] uppercase tracking-[0.12em] text-(--color-text-dim)">03</span>
              <span class="font-[family-name:var(--font-display)] text-sm font-bold uppercase tracking-wide text-(--color-text-head)">mapcreator</span>
            </button>
          </div>

          <div class="split-panel">
            <div class="split-content active" data-index="0">
              <div class="flex items-center gap-2.5 mb-3">
                <h3 class="font-[family-name:var(--font-display)] text-xl md:text-2xl font-bold uppercase tracking-wide text-(--color-text-head)">crxml</h3>
                <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">Rust</span>
              </div>
              <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-4">PyPI package</p>
              <p class="text-[12px] md:text-[13px] leading-[1.8] text-(--color-text-muted) flex-1 max-w-none">
                Fast streaming parser for Crystal Reports XML exports with Rust acceleration. Streams row-by-row without loading the full document into memory, handling files of any size. Built-in pipeline stages: rename, cast types, filter, and drop fields, all chained with <code class="text-[10px] px-1 py-[1px] bg-(--color-bg) border border-(--color-border-subtle) rounded">|</code> operators for composable transformations. Parallel mode distributes batches across worker processes using Python's multiprocessing, achieving near-linear speedups on multi-core systems. Outputs DataFrames via pandas, CSV files, or lists of dicts. The pandas import is lazy, only loaded when you actually convert, keeping the CLI lightweight.
              </p>
              <div class="flex flex-wrap gap-1.5 mt-auto mb-4">
                {['Python', 'Rust', 'XML', 'pandas'].map(t => (
                  <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">{t}</span>
                ))}
              </div>
              <div class="flex gap-2">
                <a href="https://github.com/emiliano-go/crxml" target="_blank" rel="noopener noreferrer" class="text-[10px] px-2.5 py-1.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">GitHub ↗</a>
                <a href="https://pypi.org/project/crxml/" target="_blank" rel="noopener noreferrer" class="text-[10px] px-2.5 py-1.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">PyPI ↗</a>
              </div>
            </div>

            <div class="split-content" data-index="1">
              <div class="flex items-center gap-2.5 mb-3">
                <h3 class="font-[family-name:var(--font-display)] text-xl md:text-2xl font-bold uppercase tracking-wide text-(--color-text-head)">vigil</h3>
                <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">Prefect</span>
              </div>
              <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-4">Prefect flow</p>
              <p class="text-[12px] md:text-[13px] leading-[1.8] text-(--color-text-muted) flex-1 max-w-none">
                Personal GitHub activity monitoring workflow built with Prefect. Fetches events, commits, and PR activity via PyGithub, then stores structured records in ClickHouse through dbwarden's migration framework.                 Designed for automated periodic execution: the flow runs on a cron schedule, collects the latest activity since the last run, and inserts it into the warehouse. Structured logging captures each pipeline stage, and errors surface through Prefect's native notification system instead of failing silently. A simple dashboard query gives you a timeline of your open source contribution activity without relying on GitHub's own graphs.
              </p>
              <div class="flex flex-wrap gap-1.5 mt-auto mb-4">
                {['Python', 'Prefect', 'PyGithub', 'ClickHouse'].map(t => (
                  <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">{t}</span>
                ))}
              </div>
              <div class="flex gap-2">
                <a href="https://github.com/emiliano-go/vigil" target="_blank" rel="noopener noreferrer" class="text-[10px] px-2.5 py-1.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">GitHub ↗</a>
              </div>
            </div>

            <div class="split-content" data-index="2">
              <div class="flex items-center gap-2.5 mb-3">
                <h3 class="font-[family-name:var(--font-display)] text-xl md:text-2xl font-bold uppercase tracking-wide text-(--color-text-head)">mapcreator</h3>
                <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">React</span>
              </div>
              <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-4">Web application</p>
              <p class="text-[12px] md:text-[13px] leading-[1.8] text-(--color-text-muted) flex-1 max-w-none">
                Tile-based building map editor built with React and Canvas. Draw multi-floor building layouts with a grid-based editor; place walls, designate rooms, and connect them with doors, stairs, and elevators. Each floor is a separate layer, and the A* pathfinding system can route from any room to any other across floors, automatically selecting stairs or elevators. The canvas renders at 60fps with virtual scrolling for large maps. State is managed entirely through React hooks, making it easy to undo, redo, or export the map data as JSON for use in other tools. No external mapping libraries or APIs required.
              </p>
              <div class="flex flex-wrap gap-1.5 mt-auto mb-4">
                {['React', 'TypeScript', 'Canvas', 'A* Pathfinding'].map(t => (
                  <span class="text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide">{t}</span>
                ))}
              </div>
              <div class="flex gap-2">
                <a href="https://github.com/emiliano-go/mapcreator" target="_blank" rel="noopener noreferrer" class="text-[10px] px-2.5 py-1.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200">GitHub ↗</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  (() => {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      const content = document.getElementById('terminal-content');
      if (content) {
        content.innerHTML = `
          <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden init</div>
          <div class="terminal-line">Initialized DBWarden project structure</div>
          <div class="terminal-line">Created migrations directory</div>
          <div class="terminal-line">Created dbwarden.py</div>
          <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden migrate</div>
          <div class="terminal-line">[DBWarden] Applying migrations...</div>
          <div class="terminal-line">[DBWarden] All migrations applied. Pending: 0</div>
          <div class="terminal-line" style="margin-top:4px"><span style="color:var(--color-accent-dim);animation:terminal-blink 1s step-end infinite">▊</span></div>`;
      }
      return;
    }

    // ─── Terminal typing (multi-session with clear) ───
    const content = document.getElementById('terminal-content');
    if (content) {
      const sessions = [
        [
          { cmd: 'dbwarden init', output: ['Initialized DBWarden project structure', 'Created migrations directory', 'Created dbwarden.py'] },
          { cmd: 'dbwarden config', output: ['  Primary (sqlite)     sqlite:///./app.db', '  Migrations:          migrations/primary'] },
          { cmd: 'dbwarden make-migrations "create users table"', output: ['Generated changes:', '  + CREATE TABLE users', '  + CREATE TABLE posts', 'Created: primary__0001_create_core_tables.sql'] },
        ],
        [
          { cmd: 'dbwarden migrate', output: ['[DBWarden] Applying primary__0001_create_core_tables...', '[DBWarden] Migration applied (42ms)'] },
          { cmd: 'dbwarden status', output: ['  Applied:  1', '  Pending:  0', '  Status:   up-to-date'] },
          { cmd: 'dbwarden check', output: ['  CREATE TABLE users          SAFE', '  CREATE TABLE posts          SAFE', '  Result: 2 SAFE, 0 WARN'] },
        ],
        [
          { cmd: 'dbwarden history', output: ['  V0001  create_core_tables  2025-01-15'] },
          { cmd: 'dbwarden rollback --count 1', output: ['[DBWarden] Rolling back primary__0001...', '[DBWarden] Rollback complete'] },
          { cmd: 'dbwarden migrate', output: ['[DBWarden] Applying primary__0001_create_core_tables...', '[DBWarden] Migration applied (35ms)'] },
          { cmd: 'dbwarden status', output: ['  Applied:  1', '  Pending:  0', '  Status:   up-to-date'] },
        ],
      ];

      function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

      function typeChars(parent, text, base, range) {
        return new Promise(resolve => {
          let i = 0;
          function next() {
            if (i >= text.length) { resolve(); return; }
            const span = document.createElement('span');
            span.textContent = text[i];
            parent.appendChild(span);
            i++;
            setTimeout(next, base + Math.random() * range);
          }
          next();
        });
      }

      function addCmdLine() {
        const line = document.createElement('div');
        line.className = 'terminal-line';
        const prompt = document.createElement('span');
        prompt.className = 'text-(--color-accent-dim)';
        prompt.textContent = '$';
        line.appendChild(prompt);
        content.appendChild(line);
        return line;
      }

      function addOutputLine(text) {
        const line = document.createElement('div');
        line.className = 'terminal-line';
        line.textContent = text;
        content.appendChild(line);
      }

      (async () => {
        await sleep(400);

        while (true) {
          for (const block of sessions) {
            for (let i = 0; i < block.length; i++) {
              const entry = block[i];
              const isLast = i === block.length - 1;

              const cmdLine = addCmdLine();
              await typeChars(cmdLine, ' ' + entry.cmd, 50, 70);
              await sleep(300 + Math.random() * 250);

              for (const out of entry.output) {
                await sleep(120 + Math.random() * 80);
                addOutputLine(out);
              }

              if (isLast) {
                await sleep(1000 + Math.random() * 1000);
              } else {
                await sleep(800 + Math.random() * 400);
              }
            }

            const clearLine = addCmdLine();
            await typeChars(clearLine, ' clear', 50, 70);
            await sleep(2000);
            content.innerHTML = '';
            await sleep(600);
          }

          const cursorLine = document.createElement('div');
          cursorLine.className = 'terminal-line';
          const cursor = document.createElement('span');
          cursor.textContent = '▊';
          cursor.style.color = 'var(--color-accent-dim)';
          cursor.style.animation = 'terminal-blink 1s step-end infinite';
          cursorLine.appendChild(cursor);
          content.appendChild(cursorLine);
          await sleep(1500 + Math.random() * 500);
          content.innerHTML = '';
          await sleep(500);
        }
      })();
    }

  })();

  // ─── Twinkling stars with mouse parallax ───
  (() => {
    const container = document.getElementById('dbwarden-stars');
    if (!container) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const stars = [];
    const minDist = 3;
    const maxStars = 220;

    for (let i = 0; i < maxStars; i++) {
      let placed = false;
      for (let attempt = 0; attempt < 80; attempt++) {
        const x = Math.random() * 100;
        const y = Math.random() * 100;
        if (!stars.some(s => Math.hypot(s.x - x, s.y - y) < minDist)) {
          stars.push({ x, y });
          placed = true;
          break;
        }
      }
      if (!placed) break;
    }

    for (const pos of stars) {
      const star = document.createElement('span');
      const size = 1 + Math.random() * 1.5;
      star.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        background: var(--color-text-dim);
        border-radius: 50%;
        left: ${pos.x}%;
        top: ${pos.y}%;
        opacity: 0;
        will-change: transform, opacity;
      `;
      container.appendChild(star);
      const driftTargetX = Math.random() * 100;
      const driftTargetY = Math.random() * 100;
      star.__data = {
        twinkleSpeed: 0.6 + Math.random() * 1.5,
        twinklePhase: Math.random() * Math.PI * 2,
        minOpacity: 0,
        maxOpacity: 0.3 + Math.random() * 0.5,
        size: size,
        originX: pos.x,
        originY: pos.y,
        driftX: 0,
        driftY: 0,
        targetX: driftTargetX,
        targetY: driftTargetY,
        driftTimer: 0,
      };
    }

    let mouseX = 0, mouseY = 0;
    let currentX = 0, currentY = 0;

    document.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width - 0.5;
      mouseY = (e.clientY - rect.top) / rect.height - 0.5;
    });

    function animate() {
      currentX += (mouseX - currentX) * 0.04;
      currentY += (mouseY - currentY) * 0.04;

      const time = Date.now() / 1000;
      const dt = 1/60;

      const starEls = container.children;
      for (let i = 0; i < starEls.length; i++) {
        const el = starEls[i];
        const d = el.__data;

        d.driftTimer += dt;
        if (d.driftTimer > 3 + Math.random() * 4) {
          d.targetX = Math.random() * 100;
          d.targetY = Math.random() * 100;
          d.driftTimer = 0;
        }

        d.driftX += (d.targetX - (d.originX + d.driftX)) * 0.004;
        d.driftY += (d.targetY - (d.originY + d.driftY)) * 0.004;

        const parallaxX = currentX * 20 * d.size;
        const parallaxY = currentY * 20 * d.size;

        const twinkle = Math.sin(time * d.twinkleSpeed + d.twinklePhase);
        const opacity = d.minOpacity + (twinkle + 1) / 2 * (d.maxOpacity - d.minOpacity);

        const px = d.driftX + parallaxX;
        const py = d.driftY + parallaxY;

        el.style.transform = `translate(${px}px, ${py}px)`;
        el.style.opacity = Math.max(0, Math.min(1, opacity));
        el.style.left = `${d.originX}%`;
        el.style.top = `${d.originY}%`;
      }

      requestAnimationFrame(animate);
    }

    animate();
  })();

  // ─── Split-layout: click nav to show detail ───
  (() => {
    const layout = document.getElementById('split-layout');
    if (!layout) return;

    const btns = layout.querySelectorAll('.split-btn');
    const contents = layout.querySelectorAll('.split-content');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-target');

        btns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        contents.forEach(c => c.classList.remove('active'));
        const target = layout.querySelector(`.split-content[data-index="${idx}"]`);
        if (target) target.classList.add('active');
      });
    });
  })();
</script>

