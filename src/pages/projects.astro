        color: var(--color-accent);
        letter-spacing: 0.05em;
        border-radius: 3px;
      }
    </style>
    <script>
    (function() {
      document.querySelectorAll('.typing-text').forEach(function(el) {
        var text = el.getAttribute('data-text');
        if (!text) return;
        var i = 0;
        function type() {
          if (i <= text.length) {
            el.textContent = text.substring(0, i);
            i++;
            if (i <= text.length) { setTimeout(type, 50 + Math.random() * 30); }
            else { el.classList.add('typing'); }
          }
        }
        setTimeout(type, 600);
      });
    })();
    </script>

