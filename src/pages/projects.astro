---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RevealObserver from '../components/RevealObserver.astro';

const featured = {
  tag: 'Python Package · PyPI',
  name: 'DBWarden',
  desc: 'Django-like migration management for FastAPI/SQLAlchemy projects. Multi-database, dev/prod separation, SQL translation layer, FastAPI integrations.',
  tags: ['SQLAlchemy', 'FastAPI', 'CLI', 'PyPI'],
  links: [
    { label: 'GitHub', href: 'https://github.com/emiliano-go/DBWarden' },
    { label: 'PyPI', href: 'https://pypi.org/project/dbwarden/' },
  ],
  blogPosts: [
    { label: 'Read about DBWarden →', href: 'https://blog.emiliano-gandini-outeda.uy' },
  ],
};

const small = [
  {
    tag: 'Private SaaS · ETL',
    name: 'Datavyr',
    desc: 'ETL platform built for business data. Handles large XLSX, CSV, and XML files with streaming processing and real-time progress. Four tiers, production-deployed.',
    tags: ['FastAPI', 'TaskIQ', 'Redis', 'PostgreSQL', 'React'],
    private: true,
    inProgress: true,
  },
  {
    tag: 'Open Source · Uruguay',
    name: 'LibreCourseUY',
    desc: 'An open source organization driving FOSS adoption in Uruguay. We host community events and workshops, maintain open infrastructure, develop educational tools, and run librecourse.uy — a growing directory of free and community-driven courses across Uruguay. ~30 people managing the org and +300 members contributing.',
    tags: ['Community', 'Open Source', 'Python', 'Infra'],
    links: [
      { label: 'GitHub', href: 'https://github.com/LibreCourseUY' },
      { label: 'Website', href: 'https://librecourse.uy' },
    ],
    blogPosts: [
      { label: 'Explore librecourse.uy →', href: 'https://librecourse.uy' },
      { label: 'Read the blog →', href: 'https://blog.emiliano-gandini-outeda.uy' },
    ],
  },
  {
    tag: 'Python Package · PyPI',
    name: 'acrresolv',
    desc: 'Acronym resolver for Python. Converts natural language phrases to acronyms. Currently being expanded with Machine Learning.',
    tags: ['NLP', 'Python', 'PyPI'],
    links: [
      { label: 'GitHub', href: 'https://github.com/emiliano-go/acrresolv' },
      { label: 'PyPI', href: 'https://pypi.org/project/acrresolv/' },
    ],
    codeblock: [
      '>>> from acrresolv import resolve',
      '>>> resolve("machine learning")',
      "'ML'",
    ],
  },
  {
    tag: 'Python Package · PyPI',
    name: 'seoslug',
    desc: 'Canonical URL normalization and deterministic SEO payload generation for content platforms. OG, Twitter Cards, JSON-LD from one function call.',
    tags: ['Python', 'PyPI', 'SEO', 'lxml'],
    links: [
      { label: 'GitHub', href: 'https://github.com/emiliano-go/seoslug' },
      { label: 'PyPI', href: 'https://pypi.org/project/seoslug/' },
    ],
    codeblock: [
      'from seoslug import SEOConfig, SEOEntity, build_seo_payload',
      'payload = build_seo_payload(entity, path, config)',
      'payload.canonical  # https://example.com/post/my-post',
    ],
  },
  {
    tag: 'Python Package · PyPI',
    name: 'detrack',
    desc: 'Strip tracking parameters from URLs. Deterministically. Zero dependencies. Clean UTM markers and analytics garbage from any URL.',
    tags: ['Python', 'PyPI', 'Privacy', 'URLs'],
    links: [
      { label: 'GitHub', href: 'https://github.com/emiliano-go/detrack' },
    ],
    codeblock: [
      'from detrack import detrack',
      'detrack("https://example.com?utm_source=twitter&ref=share")',
      "# https://example.com",
    ],
  },
  {
    tag: 'Community · SCP Roleplay',
    name: 'Site-Twilight',
    desc: 'Web system for a thriving SCP roleplay community running on site-twilight.com. Manages identities, factions, classified documents, and character profiles through a rich Vue-based interface with real-time updates.',
    tags: ['Vue 3', 'Pinia', 'SCP', 'Roleplay'],
    links: [
      { label: 'Website', href: 'https://site-twilight.com' },
      { label: 'GitHub', href: 'https://github.com/emiliano-go/Site-Twilight' },
    ],
    stats: [
      { label: 'users', value: '~500' },
      { label: 'version', value: 'v2' },
    ],
  },
];
---

<Layout title="Projects — Emiliano Gandini" description="Projects by Emiliano Gandini — DBWarden, Datavyr, seoslug, detrack, and more.">
  <Nav />
  <main>
    <section class="pt-24 pb-16 border-b border-(--color-border-subtle)">
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-[320px]">

        <div data-reveal data-delay="0" class="flex items-center gap-4 mb-10">
          <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">
            Projects
          </span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <!-- Featured: DBWarden -->
        <div data-reveal data-delay="0.1" class="border border-(--color-border-subtle) mb-px bg-(--color-surface) transition-all duration-300 hover:scale-[1.015] hover:bg-(--color-bg)">
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <div class="flex items-start justify-between mb-2">
                  <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim)">{featured.tag}</p>
                </div>
                <h2 class="font-[family-name:var(--font-display)] text-3xl font-bold uppercase tracking-wide text-(--color-text-head) mb-3">{featured.name}</h2>
                <p class="text-sm leading-relaxed text-(--color-text-muted) mb-5 max-w-[520px]">{featured.desc}</p>
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div class="flex flex-wrap gap-2">
                    {featured.tags.map(t => (
                      <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
                    ))}
                  </div>
                  <div class="flex flex-wrap gap-3 shrink-0">
                    {featured.links.map(link => (
                      <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
                {featured.blogPosts && (
                  <div class="flex flex-wrap gap-2 mt-4">
                    {featured.blogPosts.map(bp => (
                      <a
                        href={bp.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group inline-flex items-center gap-2 border border-(--color-accent-dim) bg-(--color-accent-dim)/10 hover:bg-(--color-accent-dim)/20 transition-all duration-200 rounded px-3 py-2 text-[12px] md:text-[11px] text-(--color-accent) hover:text-(--color-text-bright)"
                      >
                        <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                        <span>{bp.label}</span>
                        <svg class="w-3 h-3 shrink-0 -translate-x-0.5 group-hover:translate-x-0.5 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                      </a>
                    ))}
                  </div>
                )}
              </div>
              <div id="dbwarden-terminal" class="border border-(--color-border-subtle) rounded bg-(--color-bg) overflow-hidden self-start w-full">
                <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
                  <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                  <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                  <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                  <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2">terminal</span>
                </div>
                <div class="px-4 py-3 text-[11px] leading-[1.9] font-mono text-(--color-text-muted)">
                  <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden init</div>
                  <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden make-migrations <span class="text-(--color-text-dim)">"create users table"</span></div>
                  <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden migrate</div>
                  <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden status</div>
                  <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden rollback</div>
                  <div class="terminal-line"><span class="text-(--color-accent-dim)">$</span> dbwarden history</div>
                  <div id="terminal-cursor" class="text-(--color-accent-dim)">▊</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Small cards grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-(--color-border-subtle) border border-(--color-border-subtle)">
          {small.map((p, i) => {
            const hasCodeblock = p.codeblock && p.codeblock.length > 0;
            return (
              <div data-reveal data-delay={String(0.15 + i * 0.08)} class="bg-(--color-surface) flex flex-col transition-all duration-300 hover:scale-[1.015] hover:bg-(--color-bg)">
                <div class="p-5 pb-4 flex flex-col w-full h-full">
                  <div class="flex items-center justify-between mb-2 h-[20px]">
                    <p class="text-[10px] uppercase tracking-[0.1em] text-(--color-text-dim) leading-none">{p.tag}</p>
                    <div class="flex items-center gap-2 shrink-0 leading-none">
                      {p.inProgress && (
                        <span class="text-[10px] px-2 py-[3px] border border-yellow-700 text-yellow-600 tracking-wide whitespace-nowrap leading-none">In Progress</span>
                      )}
                      {p.private && (
                        <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-dim) tracking-wide whitespace-nowrap leading-none">private</span>
                      )}
                    </div>
                  </div>
                  {p.stats && (
                    <div class="flex gap-4 mb-2">
                      {p.stats.map(s => (
                        <div>
                          <span class="font-[family-name:var(--font-display)] text-lg font-bold text-(--color-text-head)">{s.value}</span>
                          <span class="text-[10px] text-(--color-text-dim) ml-1 uppercase tracking-[0.1em]">{s.label}</span>
                        </div>
                      ))}
                    </div>
                  )}
                  <h2 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head) mb-2">{p.name}</h2>
                  <p class="text-sm leading-relaxed text-(--color-text-muted) flex-1">{p.desc}</p>

                  {hasCodeblock && (
                    <div class="border border-(--color-border-subtle) rounded bg-(--color-bg) overflow-hidden my-4 w-full">
                      <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
                        <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                        <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                        <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
                        <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2">terminal</span>
                      </div>
                      <div class="px-4 py-3 text-[11px] leading-[1.9] font-mono text-(--color-text-muted)">
                        {p.codeblock!.map(line => (
                          <div><span class="text-(--color-accent-dim)">$</span> {line}</div>
                        ))}
                      </div>
                    </div>
                  )}

                  <div class="flex flex-wrap items-end justify-between gap-4 mt-auto pt-4">
                    <div class="flex flex-wrap gap-2">
                      {p.tags.map(t => (
                        <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
                      ))}
                    </div>
                    {p.links && (
                      <div class="flex flex-wrap gap-3 shrink-0">
                        {p.links.map(link => (
                          <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                            {link.label}
                          </a>
                        ))}
                      </div>
                    )}
                  </div>

                  {p.blogPosts && (
                    <div class="flex flex-wrap gap-2 mt-3 pt-3 border-t border-(--color-border-subtle)">
                      {p.blogPosts.map(bp => (
                        <a
                          href={bp.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="group inline-flex items-center gap-2 border border-(--color-accent-dim) bg-(--color-accent-dim)/10 hover:bg-(--color-accent-dim)/20 transition-all duration-200 rounded px-3 py-2 text-[12px] md:text-[11px] text-(--color-accent) hover:text-(--color-text-bright)"
                        >
                          <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                          </svg>
                          <span>{bp.label}</span>
                          <svg class="w-3 h-3 shrink-0 -translate-x-0.5 group-hover:translate-x-0.5 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                          </svg>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </section>
  </main>
  <Footer />
  <RevealObserver />
</Layout>

<style is:global>
  #terminal-cursor {
    animation: blink 1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>

<script>
  import { animate, stagger } from 'motion';

  const terminal = document.getElementById('dbwarden-terminal');
  if (terminal) {
    const lines = terminal.querySelectorAll('.terminal-line');
    const cursor = document.getElementById('terminal-cursor');

    lines.forEach(l => l.style.opacity = '0');

    const startAnimation = () => {
      animate(
        lines,
        { opacity: [0, 1], transform: ['translateY(6px)', 'translateY(0)'] },
        { delay: stagger(0.18), duration: 0.35, easing: [0.25, 0.46, 0.45, 0.94] }
      );
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startAnimation();
            observer.unobserve(terminal);
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(terminal);
  }
</script>
