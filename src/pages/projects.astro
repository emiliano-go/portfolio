      /* ─── Shield ─── */
      .local-anim-shield {
        position: relative;
      }
      .arch-mark {
        position: absolute;
        left: calc(50% + 42px);
        top: 50%;
        width: 34px;
        height: 34px;
        transform: translate(-50%, -50%);
        z-index: 1;
        opacity: 0.32;
      }
      .arch-mark path {
        fill: var(--color-text-dim);
      }
      .shield-mark {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 36px;
        height: 42px;
        transform: translate(-50%, -50%);
        z-index: 2;
      }
      .shield-mark path {
        fill: none;
        stroke: var(--color-text-dim);
        stroke-width: 2;
        stroke-linejoin: round;
        opacity: 1;
      }
      .shield-bullet {
        position: absolute;
        width: 34px;
        height: 12px;
        left: 0;
        top: 50%;
        margin-left: -17px;
        margin-top: -6px;
        animation: shield-deflect 2.35s linear infinite;
        opacity: 0;
        transform-origin: 50% 50%;
      }
      .shield-bullet svg {
        display: block;
        width: 100%;
        height: 100%;
      }
      .shield-bullet path:first-child {
        fill: var(--color-text-dim);
      }
      .shield-bullet path:last-child {
        fill: none;
        stroke: var(--color-bg);
        stroke-width: 1;
        stroke-linecap: round;
      }
      .ricochet-spark {
        position: absolute;
        left: 91px;
        top: 50%;
        width: 14px;
        height: 14px;
        margin-left: -7px;
        margin-top: -7px;
        transform: translateY(var(--iy)) scale(0.2);
        opacity: 0;
        animation: ricochet-spark 2.35s linear infinite;
        pointer-events: none;
      }
      .shield-impact {
        position: absolute;
        left: 91px;
        top: 50%;
        width: 20px;
        height: 20px;
        margin-left: -10px;
        margin-top: -10px;
        border: 1px solid var(--color-accent-dim);
        border-radius: 999px;
        opacity: 0;
        transform: translateY(var(--iy)) scale(0.25);
        animation: shield-impact 2.35s linear infinite;
        pointer-events: none;
      }
      .ricochet-spark::before,
      .ricochet-spark::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 12px;
        height: 1px;
        background: var(--color-accent-dim);
        transform-origin: left center;
      }
      .ricochet-spark::before { transform: rotate(-24deg); }
      .ricochet-spark::after { transform: rotate(34deg); }
      @keyframes shield-deflect {
        0% { transform: translate(-28px, var(--sy)) rotate(var(--in-rot)) scale(0.86); opacity: 0; }
        8% { opacity: 0.78; }
        29.8% { transform: translate(74px, var(--iy)) rotate(var(--in-rot)) scale(0.94); opacity: 0.78; }
        30% { transform: translate(74px, var(--iy)) rotate(var(--out-rot)) scale(0.9); opacity: 0.78; }
        40% { transform: translate(var(--ex), var(--ey)) rotate(var(--out-rot)) scale(0.72); opacity: 0; }
        100% { transform: translate(var(--ex), var(--ey)) rotate(var(--out-rot)) scale(0.72); opacity: 0; }
      }
      @keyframes ricochet-spark {
        0%, 28.8% { opacity: 0; transform: translateY(var(--iy)) scale(0.15); }
        30% { opacity: 0.95; transform: translateY(var(--iy)) scale(1); }
        35% { opacity: 0; transform: translateY(var(--iy)) scale(1.35); }
        100% { opacity: 0; transform: translateY(var(--iy)) scale(0.15); }
      }
      @keyframes shield-impact {
        0%, 28.8% { opacity: 0; transform: translateY(var(--iy)) scale(0.25); }
        30% { opacity: 0.7; transform: translateY(var(--iy)) scale(0.55); }
