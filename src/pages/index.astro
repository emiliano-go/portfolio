---
// Root redirect — detects preferred language and redirects
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Emiliano G.O.</title>
  <script>
    (function() {
      var stored = localStorage.getItem('lang');
      var browser = (navigator.language || '').slice(0, 2);
      var lang = stored || (browser === 'es' || browser === 'fr' ? browser : 'en');
      var path = location.pathname === '/' ? '' : location.pathname;
      var base = '/' + lang + path + location.search + location.hash;
      location.replace(base);
    })();
  </script>
</head>
<body>
  <p><a href="/en/">Continue to English</a></p>
</body>
</html>
