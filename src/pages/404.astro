---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout route="/404.html" title="404 - Page Not Found | Emiliano G.O." description="The page you are looking for does not exist.">
  <Nav />
  <main class="min-h-screen flex items-center justify-center">
    <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0 text-center">
      <h1 class="font-[family-name:var(--font-display)] text-[clamp(72px,12vw,120px)] font-bold uppercase leading-[0.92] tracking-wide text-(--color-text-head) mb-4" data-i18n="page404.heading">404</h1>
      <p class="text-sm text-(--color-text-muted) mb-8" data-i18n="page404.sub">Page not found.</p>
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-[13px] px-5 py-2.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200"
        data-i18n="page404.back"
      >
        &larr; Back home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
