        var text = el.getAttribute('data-text');
        if (!text) return;
        var i = 0;
        function type() {
          if (i <= text.length) {
            el.textContent = text.substring(0, i);
            i++;
            if (i <= text.length) { setTimeout(type, 50 + Math.random() * 30); }
