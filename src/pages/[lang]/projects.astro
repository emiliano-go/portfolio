  @keyframes section-breathe {
    0%, 100% { border-bottom-color: #1e2e2e; }
    50% { border-bottom-color: #3a6e5a; }
  }

  .split-layout {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-subtle);
  }

  .split-nav {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .split-btn {
    text-align: left;
    padding: 0.85rem 1rem;
    border: none;
    border-bottom: 1px solid var(--color-border-subtle);
    background: var(--color-surface);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: background 0.2s;
    color: var(--color-text-muted);
    font-family: inherit;
  }

  .split-btn:last-child {
    border-bottom: none;
  }

  .split-btn:hover {
    background: var(--color-bg);
  }

  .split-btn.active {
    background: var(--color-bg);
    color: var(--color-text-head);
    border-left: 2px solid var(--color-text-dim);
  }

  .split-panel {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .split-content {
    display: none;
  }

  .split-content.active {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  @media (min-width: 768px) {
    .split-layout {
      flex-direction: row;
    }

    .split-nav {
      width: 160px;
      border-bottom: none;
      border-right: 1px solid var(--color-border-subtle);
    }

    .split-btn {
      flex: 1;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .split-btn:last-child {
      border-bottom: none;
    }

    .split-panel {
      flex: 1;
      height: 400px;
      padding: 1.75rem;
      overflow-y: auto;
    }
  }
</style>
