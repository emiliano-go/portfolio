---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { createT } from '../../i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params;
const t = createT(lang!);
---

<Layout lang={lang} title="Projects | Emiliano G.O." description="DBWarden, schemap, and other Python packages - database tooling, ETL utilities, and open source projects by Emiliano Gandini Outeda.">
  <Nav lang={lang} />
  <main>

    <!-- ─── DBWarden — Dedicated Section ─── -->
    <section id="dbwarden" class="min-h-screen pt-24 pb-6 md:pt-28 md:pb-10 border-b border-(--color-border-subtle) flex flex-col justify-center relative" style="background: var(--color-bg);">
      <div id="dbwarden-stars" class="absolute inset-0 pointer-events-none overflow-hidden"></div>
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0 relative z-10">

        <div class="flex items-center gap-4 mb-6">
          <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-accent) whitespace-nowrap">{t("projects.featured")}</span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <!-- Title + desc on left, terminal on right -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 items-start">
          <div>
            <p class="text-[11px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-3">{t("projects.tag.pypi")}</p>
            <div class="flex items-end gap-3 mb-3">
              <h1 class="font-[family-name:var(--font-display)] text-[44px] md:text-[56px] font-bold uppercase leading-[0.92] tracking-wide text-(--color-text-head)">
                DBWarden
              </h1>
              <span data-pypi-version="dbwarden" class="text-[10px] px-1.5 py-[2px] border border-(--color-accent-dim) text-(--color-accent) tracking-wide rounded shrink-0">loading</span>
            </div>
            <span data-repo="emiliano-go/DBWarden" class="repo-badge text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide rounded inline-block mb-3 self-start"></span>
            <p class="text-lg md:text-xl text-(--color-text-bright) mb-6">{t("projects.dbwarden.subtitle")}</p>
            <p class="text-[13px] leading-[1.8] text-(--color-text-muted) max-w-[640px] mb-6">{t("projects.dbwarden.detail")}</p>
            <!-- 2x2 link grid -->
            <div class="grid grid-cols-2 gap-3">
              <a href="https://github.com/emiliano-go/DBWarden" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                <span>{t("projects.link.github")}</span> <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
              <a href="https://pypi.org/project/dbwarden/" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                <span>{t("projects.link.pypi")}</span> <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
              <a href="https://dbwarden.emiliano-go.com/" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                <span>{t("projects.dbwarden.docs")}</span> <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
              <a href="https://deepwiki.com/emiliano-go/DBWarden/" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center gap-1.5 text-[13px] px-4 py-2.5 border border-(--color-border) rounded hover:border-(--color-accent-dim) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                <span>{t("projects.dbwarden.deepwiki")}</span> <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
              </a>
            </div>
          </div>
          <div id="dbwarden-terminal" class="hidden md:block w-full border border-(--color-border) rounded bg-(--color-bg) overflow-hidden self-start">
            <div class="flex items-center gap-1.5 px-3 py-2 border-b border-(--color-border-subtle)">
              <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
              <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
              <span class="w-2 h-2 rounded-full bg-(--color-text-dim)"></span>
              <span class="text-[9px] text-(--color-text-dim) tracking-wide ml-2">{t("projects.terminal")}</span>
            </div>
            <div id="terminal-content" class="px-4 py-3 w-full text-[11px] leading-[1.9] font-mono text-(--color-text-muted) h-[300px] overflow-x-auto whitespace-nowrap"></div>
          </div>
        </div>

        <!-- Feature grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-4">
          {[
            { title: 'SQL-first', desc: 'Migrations are plain SQL. No runtime required.', key: 'sqlfirst' },
            { title: 'Rollback included', desc: 'Every migration carries upgrade + rollback SQL.', key: 'rollback' },
            { title: 'Schema snapshots', desc: 'Checksummed JSON after every migration for deterministic diffs.', key: 'snapshot' },
            { title: 'Column-level diffing', desc: 'Type, nullability, default, and comment changes.', key: 'diffing' },
            { title: 'Impact analysis', desc: 'AST-based scan to detect breaking changes before deploy.', key: 'impact' },
            { title: 'Offline mode', desc: 'Export model state, generate migrations anywhere, no DB needed.', key: 'offline' },
            { title: 'FastAPI integration', desc: 'Startup validation, health checks, runtime lifecycle.', key: 'fastapi' },
            { title: '5 DB dialects', desc: 'PostgreSQL, MySQL, MariaDB, SQLite, ClickHouse.', key: 'dialects' },
          ].map(f => (
            <div class="border border-(--color-border) bg-(--color-surface) p-4 transition-all duration-200 hover:bg-(--color-bg)">
              <p class="text-[11px] font-semibold text-(--color-text-bright) uppercase tracking-wide mb-1" data-i18n={`projects.feature.${f.key}`}>{f.title}</p>
              <p class="text-[11px] leading-[1.6] text-(--color-text-muted)" data-i18n={`projects.feature.${f.key}.desc`}>{f.desc}</p>
            </div>
          ))}
        </div>

        <!-- Stats bar -->
        <div id="dbwarden-stats" class="flex flex-wrap justify-center gap-3 sm:gap-6 md:gap-10 py-3 px-3 border border-(--color-border) bg-(--color-surface) rounded">
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">12</span><span class="text-xs text-(--color-text-dim) ml-1.5">{t("projects.stat.stars")}</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">1,131</span><span class="text-xs text-(--color-text-dim) ml-1.5">{t("projects.stat.tests")}</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">51K</span><span class="text-xs text-(--color-text-dim) ml-1.5">{t("projects.stat.loc")}</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">5</span><span class="text-xs text-(--color-text-dim) ml-1.5">{t("projects.stat.dialects")}</span></div>
          <div><span class="font-[family-name:var(--font-display)] text-2xl font-bold text-(--color-text-head)">15+</span><span class="text-xs text-(--color-text-dim) ml-1.5">{t("projects.stat.cli")}</span></div>
        </div>
      </div>
    </section>

    <!-- ─── seoslug ─── -->
    <section id="seoslug" class="min-h-screen pt-24 pb-6 md:pt-28 md:pb-10 border-b border-(--color-border-subtle) flex flex-col justify-center relative">
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0 relative z-10">

        <div class="flex items-center gap-4 mb-8">
          <span class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-accent) whitespace-nowrap">{t("projects.tag.webauth")}</span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <!-- Two-column grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- ─── Left column: title + description + flowchart + detail panel ─── -->
          <div class="flex flex-col gap-5">

            <!-- Title and description -->
            <div>
              <p class="text-[11px] uppercase tracking-[0.1em] text-(--color-text-dim) mb-3">PyPI</p>
              <div class="flex items-end gap-3 mb-4">
                <h1 class="font-[family-name:var(--font-display)] text-[44px] md:text-[56px] font-bold uppercase leading-[0.92] tracking-wide text-(--color-text-head)">
                  seoslug
                </h1>
                <span data-pypi-version="seoslug" class="text-[10px] px-1.5 py-[2px] border border-(--color-accent-dim) text-(--color-accent) tracking-wide rounded shrink-0">loading</span>
              </div>
              <span data-repo="emiliano-go/seoslug" class="repo-badge text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide rounded inline-block mb-3 self-start"></span>
              <p class="text-lg md:text-xl text-(--color-text-bright) mb-4">{t("projects.seoslug.subtitle")}</p>
              <p class="text-[13px] leading-[1.8] text-(--color-text-muted) mb-4">{t("projects.seoslug.detail")}</p>
              <p class="text-[13px] leading-[1.8] text-(--color-text-muted)">
                Same inputs always produce the same output - no side effects, no randomness, no hidden state. This makes seoslug ideal for static site generators, SSR frameworks, and any build pipeline where SEO metadata must be testable, cacheable, and reproducible across builds. Zero external dependencies at runtime.
              </p>
              <div class="flex flex-wrap gap-2 mt-5">
                {['Python', 'SEO', 'JSON-LD'].map(t => (
                  <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-muted) tracking-wide">{t}</span>
                ))}
              </div>
            </div>

          </div>

          <!-- ─── Right column: feature cards + tags + links ─── -->
          <div class="flex flex-col gap-4">

            <!-- Feature highlights -->
            <div class="flex flex-col gap-2">
              {[
                { title: 'Typed inputs', desc: 'SEOConfig + SEOEntity with validated fields. No raw dicts, no guessing.', key: 'typed' },
                { title: 'Deterministic by design', desc: 'Same inputs always produce the same payload. Pure function, zero side effects.', key: 'deterministic' },
                { title: 'Multi-format output', desc: 'Canonical, OG, Twitter Cards, and JSON-LD from a single call.', key: 'multi' },
                { title: 'SSG-first', desc: 'Pre-generate SEO at build time. Works with Astro, Next.js, Hugo, Jekyll.', key: 'ssg' },
                { title: 'Zero runtime deps', desc: 'Standard library only. No external packages required at runtime.', key: 'nodeps' },
                { title: 'Fully typed', desc: 'Complete type hints, MyPy and Pyright compatible out of the box.', key: 'typed' },
              ].map(f => (
                <div class="border border-(--color-border) bg-(--color-surface) p-3 md:p-4 transition-all duration-200 hover:bg-(--color-bg)">
                  <p class="text-[11px] font-semibold text-(--color-text-bright) uppercase tracking-wide mb-1">{f.title}</p>
                  <p class="text-[11px] leading-[1.6] text-(--color-text-muted)">{f.desc}</p>
                </div>
              ))}
            </div>

            <div class="flex flex-wrap gap-3">
                <a href="https://seoslug.emiliano-go.com" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                  <span>Docs</span> <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
                <a href="https://github.com/emiliano-go/seoslug" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                  <span>{t("projects.link.github")}</span> <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
                <a href="https://pypi.org/project/seoslug/" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-1.5 text-[13px] md:text-[11px] px-3 py-1.5 border border-(--color-border) rounded hover:border-(--color-text-muted) text-(--color-text-muted) hover:text-(--color-text-bright) transition-colors duration-200">
                  <span>{t("projects.link.pypi")}</span> <span class="inline-block transition-transform duration-200 group-hover:translate-x-0.5">↗</span>
                </a>
              </div>
            </div>

          </div>

        </div>

      </div>
    </section>

    <!-- ─── Local-first Tools ─── -->
    <section id="local-tools" class="py-20 md:py-24 border-b border-(--color-border-subtle) relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background: radial-gradient(ellipse at 20% 50%, var(--color-accent) 0%, transparent 60%), radial-gradient(ellipse at 80% 50%, var(--color-text-dim) 0%, transparent 60%);"></div>
      <div class="mx-auto w-[85%] md:w-[60%] max-w-none min-w-0 relative z-10">

        <div class="flex items-center gap-4 mb-12">
          <h2 class="font-[family-name:var(--font-display)] text-[13px] font-semibold uppercase tracking-[0.12em] text-(--color-text-dim) whitespace-nowrap">{t("projects.local.heading")}</h2>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- heard ─── Voice → Text → Action ─── -->
          <div class="local-card border border-(--color-border) bg-(--color-surface) p-8 flex flex-col relative group transition-colors duration-500">
            <div class="flex items-start justify-between gap-4 mb-3">
              <div class="flex items-center gap-2">
                <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head)">heard</h3>
                <span class="text-[10px] px-2 py-[3px] border border-(--color-border) text-(--color-text-dim) tracking-wide rounded">v0.1.0</span>
              </div>

              <!-- Voice → text indicator -->
              <div class="local-anim local-anim-heard" aria-hidden="true">
                <div class="heard-waveform" id="heard-waveform">
                  <script>
                  (function() {
                    var container = document.getElementById('heard-waveform');
                    if (!container) return;
                    var html = '';
                    var envelope = [0.22, 0.38, 0.7, 0.46, 0.88, 0.58, 0.96, 0.42, 0.74, 0.34, 0.52, 0.25];
                    for (var i = 0; i < envelope.length; i++) {
                      var delay = (i * 0.11).toFixed(2);
                      var dur = (1.3 + (i % 5) * 0.18).toFixed(2);
                      var low = Math.max(0.08, envelope[i] * 0.22).toFixed(2);
                      html += '<div class="wave-bar" style="--low:' + low + ';--high:' + envelope[i] + ';animation-delay:' + delay + 's;animation-duration:' + dur + 's"></div>';
                    }
                    container.innerHTML = html;
                  })();
                  </script>
                </div>
                <div class="heard-text-line"></div>
              </div>
            </div>
            <span data-repo="emiliano-go/voxd" class="repo-badge text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide rounded inline-block mb-3 self-start"></span>

            <!-- Typing animation line -->
            <div class="font-mono text-[11px] text-(--color-accent) mb-4 h-5 overflow-hidden">
              <span class="typing-text" data-text="$ say 'open firefox'"></span>
            </div>

            <p class="text-[12px] leading-[1.8] text-(--color-text-muted) flex-1 mb-5">{t("projects.heard.detail")}</p>

            <div class="flex flex-wrap gap-2 mb-4">
              <span class="tag-accent">{t("projects.tag.ai")}</span>
              <span class="tag">Python</span>
              <span class="tag">Whisper</span>
              <span class="tag">Linux</span>
              <span class="tag">evdev</span>
            </div>
            <div class="flex gap-2">
              <a href="https://github.com/emiliano-go/voxd" target="_blank" rel="noopener noreferrer" class="text-[10px] px-3 py-1.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200"><span>GitHub</span> ↗</a>
            </div>
          </div>

          <!-- trustsight ─── Shield ─── -->
          <div class="local-card border border-(--color-border) bg-(--color-surface) p-8 flex flex-col relative group transition-colors duration-500">
            <div class="flex items-start justify-between gap-4 mb-3">
              <div class="flex items-center gap-2">
                <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold uppercase tracking-wide text-(--color-text-head)">trustsight</h3>
                <span data-pypi-version="trustsight" class="text-[10px] px-2 py-[3px] border border-(--color-accent-dim) text-(--color-accent) tracking-wide rounded">loading</span>
              </div>

              <!-- Arch deflection indicator -->
              <div class="local-anim local-anim-shield" id="shield-container" aria-hidden="true">
                <div class="arch-mark">
                  <svg viewBox="0 0 128 128" aria-hidden="true"><path d="M64 10c-5.1 12.5-8.2 20.6-13.9 32.8 3.5 3.7 7.8 8 14.9 13-7.6-3.1-12.8-6.3-16.7-9.7-7.5 15.7-19.3 38.6-43.3 80.9 18.8-10.9 33.4-17.6 47-20.1-.6-2.6-1-5.4-1-8.3l.1-2.2c.5-10.3 5.6-18.2 11.5-17.7 5.9.5 10.4 9.3 9.9 19.6-.2 3-.7 5.8-1.7 8.3 13.5 2.3 28.2 9.1 47.2 20.4-3.7-6.8-7-12.9-10.2-18.8-5-3.9-10.3-9-21.1-14.5 7.4 1.9 12.8 4.2 17 6.8C81.3 59.2 73.3 37.9 64 10Z"/></svg>
                </div>
                <script>
                (function() {
                  var c = document.getElementById('shield-container');
                  if (!c) return;
                  var impactX = 71;
                  var rows = [
                    { sy: -18, iy: -10, ex: -10, ey: -42, delay: 0.1 },
                    { sy: 0, iy: 0, ex: -12, ey: 28, delay: 1.0 },
                    { sy: 19, iy: 10, ex: -8, ey: -28, delay: 1.9 }
                  ];
                  var html = '';
                  for (var i = 0; i < rows.length; i++) {
                    var r = rows[i];
                    var out = Math.atan2(r.ey - r.iy, r.ex - impactX) * 180 / Math.PI;
                    html += '<div class="shield-bullet" style="--sy:' + r.sy + 'px;--iy:' + r.iy + 'px;--ex:' + r.ex + 'px;--ey:' + r.ey + 'px;--in-rot:0deg;--out-rot:' + out.toFixed(1) + 'deg;animation-delay:' + r.delay + 's"><svg viewBox="0 0 34 12" aria-hidden="true"><path d="M1 2.2h20.5c5.3 0 9.4 1.4 11.5 3.8-2.1 2.4-6.2 3.8-11.5 3.8H1Z"/><path d="M7 2.2v7.6"/><path d="M10 6h11"/></svg></div><div class="shield-impact" style="--iy:' + r.iy + 'px;animation-delay:' + r.delay + 's"></div><div class="ricochet-spark" style="--iy:' + r.iy + 'px;animation-delay:' + r.delay + 's"></div>';
                  }
                  c.insertAdjacentHTML('beforeend', html);
                })();
                </script>
              </div>
            </div>
            <span data-repo="emiliano-go/trustsight" class="repo-badge text-[9px] px-1.5 py-[2px] border border-(--color-border) text-(--color-text-dim) tracking-wide rounded inline-block mb-3 self-start"></span>

            <div class="font-mono text-[11px] text-(--color-accent) mb-4 h-5 overflow-hidden">
              <span class="typing-text" data-text="$ trustsight diff yay-bin"></span>
            </div>

            <p class="text-[12px] leading-[1.8] text-(--color-text-muted) flex-1 mb-5">{t("projects.trustsight.detail")}</p>

            <div class="flex flex-wrap gap-2 mb-4">
              <span class="tag-accent">{t("projects.tag.ai")}</span>
              <span class="tag">Python</span>
              <span class="tag">Arch Linux</span>
              <span class="tag">Security</span>
            </div>
            <div class="flex gap-2">
              <a href="https://github.com/emiliano-go/trustsight" target="_blank" rel="noopener noreferrer" class="text-[10px] px-3 py-1.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200"><span>{t("projects.link.github")}</span> ↗</a>
              <a href="https://pypi.org/project/trustsight/" target="_blank" rel="noopener noreferrer" class="text-[10px] px-3 py-1.5 border border-(--color-border) rounded text-(--color-text-muted) hover:text-(--color-text-bright) hover:border-(--color-text-muted) transition-colors duration-200"><span>{t("projects.link.pypi")}</span> ↗</a>
            </div>
          </div>
        </div>

      </div>
    </section>

    <style is:global>
      .local-card {
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.025);
      }
      .local-card:hover {
        border-color: color-mix(in srgb, var(--color-accent-dim) 38%, var(--color-border));
      }
      .local-anim {
        width: 218px;
        height: 55px;
        border: 1px solid var(--color-border-subtle);
        background: color-mix(in srgb, var(--color-bg) 72%, transparent);
        border-radius: 6px;
        flex: 0 0 auto;
        overflow: hidden;
        opacity: 0.85;
      }

      /* ─── Waveform bars ─── */
      .local-anim-heard {
        position: relative;
      }
      .heard-waveform {
        height: 100%;
        display: flex;
        align-items: end;
        gap: 3px;
        box-sizing: border-box;
        padding: 8px 13px 16px;
      }
      .wave-bar {
        flex: 1;
        height: 100%;
        background: var(--color-text-dim);
        border-radius: 2px 2px 0 0;
        animation: wave-pulse ease-in-out infinite;
        transform-origin: bottom;
        min-height: 0;
        opacity: 0.7;
      }
      .heard-text-line {
        position: absolute;
        left: 13px;
        bottom: 7px;
        width: 82px;
        height: 1px;
        margin: 0;
        background: var(--color-accent-dim);
        transform-origin: left;
        animation: text-line-resolve 2.4s ease-in-out infinite;
        opacity: 0.65;
      }
      @keyframes wave-pulse {
        0%, 100% { transform: scaleY(var(--low)); opacity: 0.35; }
        18% { transform: scaleY(calc(var(--high) * 0.55)); opacity: 0.55; }
        42% { transform: scaleY(var(--high)); opacity: 0.82; }
        67% { transform: scaleY(calc(var(--high) * 0.38)); opacity: 0.48; }
      }
      @keyframes text-line-resolve {
        0%, 35% { transform: scaleX(0.25); opacity: 0.25; }
        60%, 100% { transform: scaleX(1); opacity: 0.75; }
      }

      /* ─── Shield ─── */
      .local-anim-shield {
        position: relative;
      }
      .arch-mark {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 42px;
        height: 42px;
        transform: translate(-50%, -50%);
        z-index: 2;
        opacity: 1;
      }
      .arch-mark path {
        fill: var(--color-text-dim);
      }
      .shield-bullet {
        position: absolute;
        width: 34px;
        height: 12px;
        left: 0;
        top: 50%;
        margin-left: -17px;
        margin-top: -6px;
        animation: shield-deflect 2.35s linear infinite;
        opacity: 0;
        transform-origin: 50% 50%;
      }
      .shield-bullet svg {
        display: block;
        width: 100%;
        height: 100%;
      }
      .shield-bullet path:first-child {
        fill: var(--color-text-dim);
      }
      .shield-bullet path:last-child {
        fill: none;
        stroke: var(--color-bg);
        stroke-width: 1;
        stroke-linecap: round;
      }
      .ricochet-spark {
        position: absolute;
        left: 88px;
        top: 50%;
        width: 14px;
        height: 14px;
        margin-left: -7px;
        margin-top: -7px;
        transform: translateY(var(--iy)) scale(0.2);
        opacity: 0;
        animation: ricochet-spark 2.35s linear infinite;
        pointer-events: none;
      }
      .shield-impact {
        position: absolute;
        left: 88px;
        top: 50%;
        width: 20px;
        height: 20px;
        margin-left: -10px;
        margin-top: -10px;
        border: 1px solid var(--color-accent-dim);
        border-radius: 999px;
        opacity: 0;
        transform: translateY(var(--iy)) scale(0.25);
        animation: shield-impact 2.35s linear infinite;
        pointer-events: none;
      }
      .ricochet-spark::before,
      .ricochet-spark::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 12px;
        height: 1px;
        background: var(--color-accent-dim);
        transform-origin: left center;
      }
      .ricochet-spark::before { transform: rotate(-24deg); }
      .ricochet-spark::after { transform: rotate(34deg); }
      @keyframes shield-deflect {
        0% { transform: translate(-28px, var(--sy)) rotate(var(--in-rot)) scale(0.86); opacity: 0; }
        8% { opacity: 0.78; }
        29.8% { transform: translate(71px, var(--iy)) rotate(var(--in-rot)) scale(0.94); opacity: 0.78; }
        30% { transform: translate(71px, var(--iy)) rotate(var(--out-rot)) scale(0.9); opacity: 0.78; }
        55% { transform: translate(var(--ex), var(--ey)) rotate(var(--out-rot)) scale(0.72); opacity: 0; }
        100% { transform: translate(var(--ex), var(--ey)) rotate(var(--out-rot)) scale(0.72); opacity: 0; }
      }
      @keyframes ricochet-spark {
        0%, 28.8% { opacity: 0; transform: translateY(var(--iy)) scale(0.15); }
        30% { opacity: 0.95; transform: translateY(var(--iy)) scale(1); }
        35% { opacity: 0; transform: translateY(var(--iy)) scale(1.35); }
        100% { opacity: 0; transform: translateY(var(--iy)) scale(0.15); }
      }
      @keyframes shield-impact {
        0%, 28.8% { opacity: 0; transform: translateY(var(--iy)) scale(0.25); }
        30% { opacity: 0.7; transform: translateY(var(--iy)) scale(0.55); }
